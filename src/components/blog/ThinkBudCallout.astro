---
import { APPS } from '../../lib/constants';

interface Props {
  variant?: 'default' | 'compact';
  context?: 'blog' | 'field-note';
}

const { variant = 'default', context = 'blog' } = Astro.props;
const app = APPS.thinkbud;

const headlines = {
  blog: 'While you\'re here — we also build apps.',
  'field-note': 'A note from the team behind these notes.',
};

const blurbs = {
  blog: 'NativeFirst makes ThinkBud — the iOS study app that turns any link, PDF, or recording into mind maps, FSRS-5 flashcards, AI podcasts, and Feynman explanations. 5-star Educational App Store certified.',
  'field-note': 'These field notes come from shipping ThinkBud — our 5-star Educational App Store certified iOS study app. If you want to see SwiftData, CloudKit sync, group chat, and Swift concurrency running in production, that\'s where they live.',
};
---

<aside class={`thinkbud-callout border-t border-border pt-10 mt-12 ${variant === 'compact' ? 'pb-0' : 'pb-2'}`}>
  <div class="rounded-2xl border border-accent/20 bg-gradient-to-br from-surface via-surface to-accent/5 p-6 sm:p-8 relative overflow-hidden">
    <!-- Decorative glow -->
    <div class="absolute -top-12 -right-12 w-48 h-48 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative grid sm:grid-cols-[auto,1fr,auto] gap-5 sm:gap-6 items-center">
      <!-- Icon -->
      <a href="/apps/thinkbud" class="flex-shrink-0 mx-auto sm:mx-0">
        <img
          src={app.icon}
          alt={`${app.name} app icon`}
          class="w-16 h-16 sm:w-20 sm:h-20 rounded-[18px] shadow-lg hover:scale-105 transition-transform"
          loading="lazy"
        />
      </a>

      <!-- Copy -->
      <div class="text-center sm:text-left min-w-0">
        <div class="flex items-center justify-center sm:justify-start gap-2 mb-1.5">
          <span class="text-[10px] uppercase tracking-wider font-semibold text-accent">{headlines[context]}</span>
          <span class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-[10px] font-medium text-amber-300">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
            5★ Educational
          </span>
        </div>
        <h3 class="font-display font-bold text-lg sm:text-xl text-white mb-2 leading-snug">
          <a href="/apps/thinkbud" class="hover:text-accent transition-colors">{app.name}</a>
          <span class="text-text-muted font-normal text-base"> — {app.tagline}</span>
        </h3>
        <p class="text-sm text-text-muted leading-relaxed">
          {blurbs[context]}
        </p>
      </div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center sm:justify-end gap-2 sm:gap-3 flex-shrink-0">
        <a
          href="/apps/thinkbud"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-border bg-bg/50 text-white text-sm font-medium hover:border-accent hover:text-accent transition-all whitespace-nowrap"
        >
          Learn more
        </a>
        <a
          href={app.appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full gradient-brand text-white text-sm font-semibold hover:scale-105 transition-transform whitespace-nowrap"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          App Store
        </a>
      </div>
    </div>
  </div>
</aside>
