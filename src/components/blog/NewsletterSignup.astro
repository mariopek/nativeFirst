---
/**
 * Newsletter signup — wraps the Beehiiv embed iframe in our brand styling.
 *
 * The Beehiiv embed.js + attribution.js scripts are loaded globally in
 * BaseLayout, so this component just renders the iframe + surrounding context.
 *
 * Three variants:
 *   - hero      : big section with marketing copy on left + form on right.
 *                 For homepage, /newsletter dedicated page, Field Notes landing.
 *   - inline    : compact, just-the-iframe with light framing.
 *                 For end of blog/field-note posts.
 *   - compact   : centered, single-column, minimal.
 *                 For sidebars or anywhere with limited space.
 */

interface Props {
  variant?: 'hero' | 'inline' | 'compact';
  title?: string;
  description?: string;
  bullets?: string[];
}

const {
  variant = 'inline',
  title,
  description,
  bullets,
} = Astro.props;

// Beehiiv form constants
const FORM_ID = 'a65383fe-bb94-4d04-a902-e5333f4acca2';
const IFRAME_SRC = `https://subscribe-forms.beehiiv.com/${FORM_ID}`;
const IFRAME_WIDTH = 408;
const IFRAME_HEIGHT = 259;

// Default copy per variant
const defaultTitle = title || 'Field notes in your inbox.';
const defaultDescription =
  description ||
  "One email a week — honest iOS dev write-ups from shipped apps. Swift, SwiftUI, SwiftData, and the rest of Apple's stack. No tutorials, no fluff.";
const defaultBullets = bullets || [
  'Weekly. Honest. Skim-friendly.',
  'Real bugs, real fixes, real tradeoffs.',
  'No course pitches, no AI-generated filler.',
];
---

{variant === 'hero' && (
  <section class="newsletter-hero relative py-16 sm:py-20 overflow-hidden bg-bg">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-accent-blue/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr,auto] gap-10 lg:gap-16 items-center">
        <!-- Left: marketing copy -->
        <div>
          <div class="inline-flex items-center gap-2 badge bg-accent/15 text-accent mb-5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            NEWSLETTER
          </div>
          <h2 class="font-display font-black tracking-tight text-3xl sm:text-4xl md:text-5xl text-white mb-4 leading-tight">
            {defaultTitle}
          </h2>
          <p class="text-lg text-text-muted leading-relaxed mb-6 max-w-xl">
            {defaultDescription}
          </p>
          <ul class="space-y-2.5">
            {defaultBullets.map((bullet) => (
              <li class="flex items-start gap-2.5 text-sm text-text-muted">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Beehiiv iframe -->
        <div class="newsletter-iframe-wrapper rounded-2xl overflow-hidden border border-border shadow-2xl shadow-black/40 bg-surface">
          <iframe
            src={IFRAME_SRC}
            class="beehiiv-embed block"
            data-test-id="beehiiv-embed"
            frameborder="0"
            scrolling="no"
            loading="lazy"
            title="Subscribe to NativeFirst Field Notes"
            style={`width: ${IFRAME_WIDTH}px; height: ${IFRAME_HEIGHT}px; max-width: 100%; background-color: transparent;`}
          ></iframe>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'inline' && (
  <aside class="newsletter-inline border-t border-border pt-10 mt-12">
    <div class="rounded-2xl border border-accent/20 bg-gradient-to-br from-surface via-surface to-accent/5 p-6 sm:p-8 relative overflow-hidden">
      <div class="absolute -top-12 -right-12 w-48 h-48 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative grid sm:grid-cols-[1fr,auto] gap-6 items-center">
        <div class="text-center sm:text-left">
          <div class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-wider font-semibold text-accent mb-2">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            Newsletter
          </div>
          <h3 class="font-display font-bold text-lg sm:text-xl text-white leading-snug mb-2">
            Liked this? Get the next one in your inbox.
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            One honest iOS dev write-up a week. No tutorials, no fluff. Unsubscribe any time.
          </p>
        </div>

        <div class="newsletter-iframe-wrapper rounded-xl overflow-hidden border border-border bg-bg/50 mx-auto sm:mx-0">
          <iframe
            src={IFRAME_SRC}
            class="beehiiv-embed block"
            data-test-id="beehiiv-embed"
            frameborder="0"
            scrolling="no"
            loading="lazy"
            title="Subscribe to NativeFirst Field Notes"
            style={`width: ${IFRAME_WIDTH}px; height: ${IFRAME_HEIGHT}px; max-width: 100%; background-color: transparent;`}
          ></iframe>
        </div>
      </div>
    </div>
  </aside>
)}

{variant === 'compact' && (
  <div class="newsletter-compact">
    <div class="rounded-2xl border border-border bg-surface p-5 sm:p-6 text-center">
      <h3 class="font-display font-bold text-base text-white mb-2">
        {defaultTitle}
      </h3>
      <p class="text-xs text-text-muted leading-relaxed mb-4">
        Weekly iOS dev field notes. No fluff.
      </p>
      <div class="newsletter-iframe-wrapper rounded-lg overflow-hidden border border-border bg-bg/50 mx-auto inline-block">
        <iframe
          src={IFRAME_SRC}
          class="beehiiv-embed block"
          data-test-id="beehiiv-embed"
          frameborder="0"
          scrolling="no"
          loading="lazy"
          title="Subscribe to NativeFirst Field Notes"
          style={`width: ${IFRAME_WIDTH}px; height: ${IFRAME_HEIGHT}px; max-width: 100%; background-color: transparent;`}
        ></iframe>
      </div>
    </div>
  </div>
)}
