---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import RenovationEstimator from '../../components/renovise/RenovationEstimator';

// SoftwareApplication JSON-LD
const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Renovise',
  description: 'Free home renovation cost estimator. Get instant, data-backed estimates for bathroom, kitchen, basement, and whole-house remodels — adjusted for your ZIP code.',
  operatingSystem: 'iOS',
  applicationCategory: 'UtilitiesApplication',
  url: 'https://nativefirstapp.com/tools/renovation-estimator',
  image: 'https://nativefirstapp.com/images/apps/renovise-icon.svg',
  author: {
    '@type': 'Organization',
    name: 'NativeFirst',
    url: 'https://nativefirstapp.com',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  featureList: 'Cost estimation, Regional pricing, ROI calculator, Cost breakdown, Timeline estimates, Shopping lists',
};

// FAQPage JSON-LD
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a bathroom remodel cost in 2025?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A bathroom remodel costs between $3,000 and $100,000 depending on scope. A cosmetic refresh runs $3,000-$10,000, a mid-range remodel $10,000-$25,000, a full renovation $25,000-$50,000, and a luxury remodel $50,000-$100,000. The national average is around $15,000-$25,000 for a mid-range bathroom renovation. Costs vary significantly by location — New York City runs 45% above average while Houston is 5% below.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a kitchen renovation cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Kitchen renovations range from $5,000 for a cosmetic refresh to $150,000+ for a luxury remodel. A minor kitchen remodel (cosmetic) costs $5,000-$20,000, mid-range runs $25,000-$50,000, a full renovation $50,000-$80,000, and luxury $80,000-$150,000. Cabinets are the biggest expense at 28% of total cost. Minor kitchen remodels deliver the best ROI at 113%.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the average cost per square foot for home renovation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Home renovation costs per square foot vary widely by room and scope. Kitchens average $100-$300/sqft, bathrooms $100-$400/sqft, living rooms $18-$230/sqft, and basements $15-$175/sqft. A whole-house remodel runs $35-$350/sqft depending on whether it is a cosmetic refresh or luxury renovation. These are national averages — your actual cost depends on location, materials, and contractor rates.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much should I budget for home renovation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '78% of homeowners exceed their renovation budget, with 35% going over by $10,000 or more. Experts recommend adding a 10-20% contingency buffer on top of your estimate. For a mid-range renovation, budget $50-$100 per square foot as a starting point. The median US home renovation in 2024 was $20,000. Use our free estimator above to get a range specific to your room, scope, and location.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do renovation costs vary by location?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, significantly. Renovation costs in New York City are 40-45% above the national average, San Francisco 48-52% above, and Los Angeles 32-38% above. On the other hand, cities like Cleveland are 15% below average, Houston 5% below, and Phoenix 8% below. Our estimator uses ZIP code data from RSMeans City Cost Index to adjust estimates for your specific area.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is this renovation cost estimator free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, the web estimator is completely free with no signup, no email, and no lead generation. You get instant cost estimates, breakdowns, ROI data, and timeline information. For detailed materials lists, component-level costs, and shopping breakdowns, download the Renovise iOS app (coming soon to the App Store).',
      },
    },
  ],
};

// HowTo JSON-LD — helps Google show rich results for the estimator tool
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Estimate Home Renovation Costs',
  description: 'Use the free Renovise cost estimator to get instant, data-backed renovation cost estimates adjusted for your ZIP code.',
  totalTime: 'PT1M',
  tool: { '@type': 'HowToTool', name: 'Renovise Cost Estimator' },
  step: [
    {
      '@type': 'HowToStep',
      name: 'Choose Your Room',
      text: 'Select the room you want to renovate: bathroom, kitchen, living room, bedroom, basement, outdoor, garage, or whole house.',
      position: 1,
    },
    {
      '@type': 'HowToStep',
      name: 'Set Your Scope',
      text: 'Choose the renovation level: cosmetic refresh ($), mid-range update ($$), full renovation ($$$), or luxury remodel ($$$$).',
      position: 2,
    },
    {
      '@type': 'HowToStep',
      name: 'Enter Details and Get Your Estimate',
      text: 'Enter the square footage and optionally your ZIP code for regional pricing. Get instant budget, mid-range, and premium cost estimates with breakdowns, ROI data, and timeline.',
      position: 3,
    },
  ],
};

const features = [
  {
    title: 'Real Cost Data',
    description: 'Prices sourced from Angi, HomeGuide, NerdWallet, and the JLC 2025 Cost vs. Value Report.',
    icon: 'chart',
  },
  {
    title: 'Regional Pricing',
    description: 'Costs adjusted by ZIP code using RSMeans data. NYC is 45% above average — your estimate reflects that.',
    icon: 'map',
  },
  {
    title: 'No Signup Required',
    description: 'No email, no phone number, no lead gen. Just enter your details and get numbers. That\'s it.',
    icon: 'lock',
  },
  {
    title: 'ROI Insights',
    description: 'See how much of your investment you can expect to recoup at resale, backed by industry reports.',
    icon: 'trending',
  },
  {
    title: 'Cost Breakdown',
    description: 'See where your money goes — labor, materials, fixtures, permits — with percentage breakdowns.',
    icon: 'layers',
  },
  {
    title: 'Instant Results',
    description: 'Budget, mid-range, and premium estimates in seconds. No waiting for contractor callbacks.',
    icon: 'zap',
  },
];

const featureIcons: Record<string, string> = {
  chart: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  map: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  lock: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
  trending: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  layers: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
  zap: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
};
---

<PageLayout
  title="Free Home Renovation Cost Estimator — Renovise"
  description="Get instant, data-backed renovation cost estimates for any room. Bathroom, kitchen, basement, and more — adjusted for your ZIP code. No signup required."
  keywords="renovation cost estimator, bathroom remodel cost, kitchen renovation cost, home renovation budget, remodel estimate calculator, home remodel cost 2025, renovation cost per square foot"
  image="/images/og/renovation-estimator-og.svg"
  type="website"
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative flex items-center bg-bg hero-gradient overflow-hidden py-20 sm:py-28">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-yellow/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="text-center max-w-3xl mx-auto">
        <div class="flex items-center justify-center gap-4 mb-8">
          <img
            src="/images/apps/renovise-icon.svg"
            alt="Renovise app icon"
            width="80"
            height="80"
            class="w-16 h-16 sm:w-20 sm:h-20 rounded-[18px] shadow-2xl icon-glow"
          />
          <div class="text-left">
            <span class="font-display font-black tracking-tight text-3xl sm:text-4xl text-white">
              Renovise
            </span>
            <span class="flex items-center gap-1.5 mt-1 px-3 py-1 rounded-full bg-bg/10 backdrop-blur-sm border border-white/10 text-xs text-text-muted w-fit">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
              </svg>
              Coming Soon on iOS
            </span>
          </div>
        </div>

        <h1 class="font-display font-bold text-2xl sm:text-3xl md:text-5xl text-white mb-4 leading-tight">
          Free Home Renovation<br /><span class="gradient-text">Cost Estimator</span>
        </h1>

        <p class="text-lg text-text-muted mb-4 leading-relaxed max-w-xl mx-auto">
          Free, instant renovation cost estimates backed by real market data. No signup. No contractors calling you at dinner. Just numbers.
        </p>

        <div class="flex justify-center mb-8">
          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-surface border border-border text-xs font-medium text-text-muted">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            US Market Only &mdash; pricing data covers all 50 states
          </span>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#estimator"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-full gradient-brand text-white font-semibold text-base hover:scale-105 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300"
          >
            Try the Free Estimator
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a
            href="/blog/home-renovation-costs-2026-what-to-expect"
            class="inline-flex items-center gap-2 px-6 py-4 rounded-full border border-border text-text-muted font-medium hover:bg-surface hover:text-white transition-all duration-300"
          >
            Read the Research
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Estimator Section -->
  <section id="estimator" class="py-16 sm:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
          Renovation <span class="gradient-text">Cost Estimator</span>
        </h2>
        <p class="text-text-muted max-w-lg mx-auto">
          Select your room, choose a scope, enter the size — get budget, mid-range, and premium estimates instantly.
        </p>
      </div>

      <RenovationEstimator client:load />
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
          How It <span class="gradient-text">Works</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-8 max-w-3xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl gradient-brand flex items-center justify-center text-2xl font-bold text-white">
            1
          </div>
          <h3 class="font-display font-semibold text-white mb-2">Choose Your Room</h3>
          <p class="text-sm text-text-muted">Bathroom, kitchen, basement, bedroom — 8 room types with real pricing data.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl gradient-brand flex items-center justify-center text-2xl font-bold text-white">
            2
          </div>
          <h3 class="font-display font-semibold text-white mb-2">Set Your Scope</h3>
          <p class="text-sm text-text-muted">From cosmetic refresh to luxury remodel — pick the level that matches your plans.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl gradient-brand flex items-center justify-center text-2xl font-bold text-white">
            3
          </div>
          <h3 class="font-display font-semibold text-white mb-2">Get Your Estimate</h3>
          <p class="text-sm text-text-muted">Instant budget, mid-range, and premium ranges — adjusted for your ZIP code.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-16 sm:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
          Why <span class="gradient-text">Renovise</span>
        </h2>
        <p class="text-text-muted max-w-lg mx-auto">
          Built because getting three wildly different quotes for the same bathroom shouldn't be normal.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {features.map((feature) => (
          <div class="group relative rounded-2xl border border-border bg-bg p-8 hover:-translate-y-1 hover:shadow-xl hover:border-accent/40 transition-all duration-300">
            <div class="w-12 h-12 mb-5 rounded-xl gradient-brand flex items-center justify-center">
              <Fragment set:html={featureIcons[feature.icon]} />
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {feature.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- App Showcase -->
  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
          The Full Experience on <span class="gradient-text">iOS</span>
        </h2>
        <p class="text-text-muted max-w-xl mx-auto">
          The web estimator gives you the big picture. The app gives you everything else.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="text-2xl mb-3">📋</div>
          <h3 class="font-display font-semibold text-white mb-1">Shopping Lists</h3>
          <p class="text-xs text-text-muted leading-relaxed">Every material priced and organized. Take it to the store or share with your contractor.</p>
        </div>
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="text-2xl mb-3">📸</div>
          <h3 class="font-display font-semibold text-white mb-1">AI Room Scanner</h3>
          <p class="text-xs text-text-muted leading-relaxed">Snap a photo, get a smarter estimate. AI measures and identifies room features automatically.</p>
        </div>
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="text-2xl mb-3">📊</div>
          <h3 class="font-display font-semibold text-white mb-1">Component Costs</h3>
          <p class="text-xs text-text-muted leading-relaxed">Toilet, shower, cabinets, countertops — individual item costs with lo/mid/hi ranges.</p>
        </div>
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="text-2xl mb-3">🔒</div>
          <h3 class="font-display font-semibold text-white mb-1">100% On-Device</h3>
          <p class="text-xs text-text-muted leading-relaxed">No account, no cloud, no data collection. Your renovation plans stay on your phone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-24 bg-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
          Frequently Asked <span class="gradient-text">Questions</span>
        </h2>
        <p class="text-text-muted">
          Common questions about renovation costs and how the estimator works.
        </p>
      </div>

      <div class="space-y-3">
        {faqSchema.mainEntity.map((item) => (
          <details class="group rounded-2xl border border-border bg-surface overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-display font-semibold text-white hover:text-accent transition-colors">
              {item.name}
              <svg class="w-5 h-5 shrink-0 text-text-muted group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-text-muted leading-relaxed">
              {item.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-24 gradient-brand relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-40 h-40 border border-white/20 rounded-full"></div>
      <div class="absolute bottom-10 right-10 w-60 h-60 border border-white/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 border border-white/10 rounded-full"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <img
        src="/images/apps/renovise-icon.svg"
        alt="Renovise"
        width="64"
        height="64"
        class="w-16 h-16 mx-auto mb-6 rounded-[14px] shadow-2xl"
      />
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
        Get the Full Experience
      </h2>
      <p class="text-lg text-white/80 mb-8 max-w-xl mx-auto">
        Detailed materials lists, component-level costs, AI room scanner, and shopping breakdowns — all on your iPhone.
      </p>
      <div class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-bg text-accent font-semibold text-base">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
        Coming Soon on the App Store
      </div>
    </div>
  </section>

</PageLayout>
