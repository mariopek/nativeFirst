---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterSignup from '../../components/blog/NewsletterSignup.astro';
import AasaValidator from '../../components/tools/AasaValidator';
import { SITE } from '../../lib/constants';

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Universal Links / AASA Validator',
  description:
    "Free apple-app-site-association (AASA) validator for iOS Universal Links. Fetches your AASA file, runs every check Apple does, and tells you exactly what to fix when Universal Links don't open your app.",
  url: `${SITE.url}/tools/aasa-validator`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  browserRequirements: 'Modern browser with JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'NativeFirst', url: SITE.url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools` },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'AASA Validator',
      item: `${SITE.url}/tools/aasa-validator`,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is an apple-app-site-association (AASA) file?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "AASA is the JSON file iOS reads to decide whether tapping a URL on your domain should open your app instead of Safari. It lives at https://yourdomain.com/.well-known/apple-app-site-association, must be served over HTTPS with no redirects, and must be valid JSON. Without a correctly served AASA file, Universal Links silently fall back to opening Safari.",
      },
    },
    {
      '@type': 'Question',
      name: 'Why do my Universal Links open Safari instead of my app?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Almost always one of: the AASA file isn't served over HTTPS, the server returns a redirect (Apple does NOT follow redirects since iOS 11), the Content-Type is text/html instead of application/json, the appID has a typo (must be TEAMID.bundle.id format), or the path patterns don't match the URL. This validator catches all five.",
      },
    },
    {
      '@type': 'Question',
      name: 'Where exactly should the AASA file live on my server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Apple checks https://yourdomain.com/.well-known/apple-app-site-association first (preferred since iOS 13). The legacy location https://yourdomain.com/apple-app-site-association still works but is deprecated. Both must be served over HTTPS with status 200 and Content-Type application/json. No redirects, no auth.",
      },
    },
    {
      '@type': 'Question',
      name: 'How do I find my Team ID for the appID?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Apple Developer Portal → Account → Membership → "Team ID" — it\'s a 10-character string of uppercase letters and numbers. Combine with your bundle ID using a dot: "ABCD123456.com.example.myapp". Each appID in the AASA file must follow this exact format.',
      },
    },
    {
      '@type': 'Question',
      name: 'What\'s the difference between paths and components?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '"paths" is the legacy format (iOS 9-12) — a flat array of path patterns with limited wildcards. "components" (iOS 13+) is the modern format — an array of objects with finer control over the path, query string, fragment, and exclusion. Both still work, but components gives you better matching. Migrate to components when you can.',
      },
    },
    {
      '@type': 'Question',
      name: "Apple's Branch Validator already exists. Why use this one?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Branch's validator is good but is owned by a paid analytics product, mixes Branch-specific guidance with Apple's, and asks for sign-in. This tool is free, no signup, runs every check Apple does (and a few they don't document well), and tells you exactly which line of your AASA to fix. We made it because we hit the same Universal Links debugging hell shipping our own apps.",
      },
    },
  ],
};
---

<PageLayout
  title="AASA Validator — Fix Universal Links That Won't Open Your iOS App | NativeFirst"
  description="Free apple-app-site-association (AASA) validator. Paste your domain, get every Universal Links check Apple runs — HTTPS, no-redirect, Content-Type, appID format, paths vs components — plus the exact fix when one fails. Stop guessing why your Universal Links open Safari instead of your app."
  keywords="AASA validator, apple-app-site-association validator, universal links not working, universal links validator, .well-known apple-app-site-association, AASA file checker, iOS deep link validator, universal links debugging, applinks JSON validator, NSPrivacyTracking, apple app site association generator"
>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative py-12 sm:py-16 overflow-hidden bg-bg">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-accent-blue/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-text-muted/80 mb-6">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/tools" class="hover:text-accent transition-colors">Tools</a>
        <span class="mx-2">/</span>
        <span class="text-text-muted">AASA Validator</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 badge bg-accent/15 text-accent mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
          </svg>
          FREE TOOL · iOS UNIVERSAL LINKS
        </div>

        <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl md:text-5xl text-white mb-4 leading-tight">
          Why your Universal Links open Safari instead of your app.
        </h1>
        <p class="text-lg text-text-muted leading-relaxed mb-2">
          Paste your domain. We fetch <code class="font-mono text-base px-2 py-0.5 rounded bg-surface border border-border text-white">/.well-known/apple-app-site-association</code> server-side and run every check iOS does — HTTPS, no-redirect, Content-Type, JSON validity, appID format, paths/components — plus the exact fix when one fails.
        </p>
        <p class="text-sm text-text-muted/80">
          Server-side fetch (no CORS issues). No signup. We don't log your domains.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick context -->
  <section class="bg-surface border-y border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <details class="group py-5">
        <summary class="cursor-pointer flex items-center justify-between gap-3 hover:opacity-80 transition-opacity">
          <h2 class="font-display font-semibold text-white text-base sm:text-lg">
            What's an AASA file? (read this if your Universal Links won't open the app)
          </h2>
          <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-5 pt-5 border-t border-border/40 prose prose-invert prose-sm max-w-3xl prose-p:text-text-muted prose-strong:text-white prose-code:text-accent prose-code:font-mono prose-code:text-xs prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:bg-bg prose-code:border prose-code:border-border prose-code:before:content-[''] prose-code:after:content-[''] prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
          <p>
            <strong>apple-app-site-association</strong> (AASA) is the JSON file iOS uses to decide whether to open your app or Safari when someone taps a link on your domain. It lives at <code>https://yourdomain.com/.well-known/apple-app-site-association</code>, contains your app's bundle identifier and the URL paths your app handles, and Apple downloads it the first time the device sees your app or domain.
          </p>
          <p>
            Five things have to be exactly right:
          </p>
          <ol>
            <li><strong>HTTPS only</strong> — Apple rejects HTTP outright</li>
            <li><strong>No redirects</strong> — since iOS 11, Apple does NOT follow 301/302; the file must be at the exact path</li>
            <li><strong>Content-Type</strong> — should be <code>application/json</code>, not <code>text/html</code></li>
            <li><strong>Valid JSON</strong> — strict, no trailing commas, no comments</li>
            <li><strong>appID format</strong> — must be <code>TEAMID.bundle.id</code> (10-char Team ID + dot + bundle ID)</li>
          </ol>
          <p>
            Miss any one of these and Universal Links silently fall back to Safari. There's no error in the console, no UI hint, nothing in the system logs unless you know to check Console.app for <code>swcd</code> messages. <strong>That's why this tool exists.</strong>
          </p>
          <p class="text-text-muted/70 italic">
            For deeper debugging tactics, see the <a href="/learn/field-notes">Field Notes</a> on real iOS dev practice.
          </p>
        </div>
      </details>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-12 sm:py-16 bg-bg">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <AasaValidator client:load />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 sm:py-16 bg-surface border-y border-border/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black tracking-tight text-2xl sm:text-3xl text-white mb-3">
        Universal Links FAQ
      </h2>
      <p class="text-text-muted mb-10">
        Quick answers to the questions every iOS dev hits when Universal Links don't behave.
      </p>

      <div class="space-y-4">
        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Why do my Universal Links open Safari instead of my app?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            Almost always one of: the AASA file isn't served over HTTPS, the server returns a redirect (Apple doesn't follow them since iOS 11), Content-Type is <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">text/html</code> instead of <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">application/json</code>, the appID has a typo (must be <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">TEAMID.bundle.id</code>), or your path patterns don't match. This validator catches all five.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Where exactly should the AASA file live?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            Apple checks <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">/.well-known/apple-app-site-association</code> first (preferred since iOS 13). The legacy <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">/apple-app-site-association</code> still works but is deprecated. Both must be HTTPS, status 200, no redirects, no auth.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              How do I find my Team ID for the appID?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            Apple Developer Portal → Account → Membership → "Team ID" (10-character uppercase string). Combine with your bundle ID: <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">ABCD123456.com.example.myapp</code>.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              paths vs components — which should I use?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">paths</code> is the legacy format (iOS 9-12) — flat array of patterns with limited wildcards. <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">components</code> (iOS 13+) is modern — array of objects with finer control over path, query string, fragment, and exclusion. Both work; components is better. This tool flags legacy paths as a warning, not an error.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              I changed my AASA but iOS still uses the old version. Why?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            iOS aggressively caches AASA files. To force a refresh during development: delete the app, reinstall, OR use the new <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">apple-app-site-association</code> SwiftUI debug entitlement. In production, Apple's <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">swcd</code> daemon refreshes the file on its own schedule (~once per device per day for active apps).
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-bg p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Does this send my domain anywhere?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            We fetch your AASA file server-side from a Cloudflare Pages Function (browsers can't fetch it directly because AASA files don't send CORS headers). Your domain isn't logged. The validation result isn't stored. Each check runs fresh. The User-Agent we use identifies our validator to your server logs (<code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface border border-border text-white">NativeFirst-AASA-Validator/1.0</code>) so it's clear who hit your endpoint.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Cross-link cards -->
  <section class="py-12 bg-bg">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-5">
        <a
          href="/tools/privacy-manifest-generator"
          class="group rounded-2xl border border-border bg-surface p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2">
            Sister tool
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            Privacy Manifest Generator
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            While you're fixing iOS plumbing — generate a valid <code class="font-mono text-[11px] px-1 py-0.5 rounded bg-bg border border-border text-white">PrivacyInfo.xcprivacy</code> in 30 seconds. Skip the ITMS-91056 App Review bounce.
          </p>
        </a>

        <a
          href="/apps/thinkbud"
          class="group rounded-2xl border border-border bg-surface p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2 inline-flex items-center gap-2">
            <span>OUR APP</span>
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-500/10 border border-amber-500/30 text-amber-300 text-[9px]">★ 5★ Educational</span>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            ThinkBud — turn anything into mind maps + flashcards
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            We make ThinkBud — drop any link, PDF, or recording, get mind maps, FSRS-5 flashcards, AI podcasts. The energy behind these tools comes from shipping it.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter (bottom only) -->
  <NewsletterSignup variant="hero" />
</PageLayout>
