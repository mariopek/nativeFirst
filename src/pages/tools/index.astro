---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterSignup from '../../components/blog/NewsletterSignup.astro';

const tools = [
  {
    slug: 'app-store-hero-maker',
    title: 'App Store Hero Maker',
    description:
      "App Store screenshots that actually convert. iOS 26 Liquid Glass templates, panorama hero pair (Spotify-style), live conversion guidance, brand color extraction, bulk export to every Apple size. The free designer with what paid tools forgot.",
    tag: 'iOS · iPad · Conversion',
    icon: 'sparkles',
    status: 'live' as const,
  },
  {
    slug: 'app-icon-generator',
    title: 'App Icon Generator',
    description:
      "Drop one 1024×1024 source. Get every Apple icon size — iPhone, iPad, Mac, Watch, Vision Pro — plus iOS 26 Liquid Glass tinted and dark variants, packaged as Xcode-ready AppIcon.appiconset.",
    tag: 'iOS · macOS · watchOS · visionOS',
    icon: 'photo',
    status: 'live' as const,
  },
  {
    slug: 'aasa-validator',
    title: 'Universal Links / AASA Validator',
    description:
      "Why your Universal Links open Safari instead of your app. Paste a domain, get every check Apple runs on the apple-app-site-association file plus the exact fix when one fails.",
    tag: 'iOS',
    icon: 'link',
    status: 'live' as const,
  },
  {
    slug: 'privacy-manifest-generator',
    title: 'Privacy Manifest Generator',
    description:
      "Generate a valid PrivacyInfo.xcprivacy file in 30 seconds. Covers Required Reasons APIs and tracking domains. Skip the ITMS-91056 App Review bounce.",
    tag: 'iOS',
    icon: 'shield',
    status: 'live' as const,
  },
  // Future tools land here — Bundle ID checker, TestFlight link tester, etc.
];

// Map icon name → SVG path. Keep simple — small set, matches existing style.
const ICON_PATHS: Record<string, string> = {
  shield:
    'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  link:
    'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  photo:
    'M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z',
  sparkles:
    'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z',
};
---

<PageLayout
  title="Free iOS Developer Tools — NativeFirst"
  description="Free, no-signup tools for iOS developers. Privacy Manifest Generator and more in the works. Built by the NativeFirst team — practical utilities that make shipping native Apple apps less painful."
  keywords="free iOS developer tools, iOS dev utilities, Swift developer tools, App Store compliance tools, privacy manifest generator, indie iOS dev tools"
>
  <!-- Hero -->
  <section class="relative py-16 sm:py-20 overflow-hidden bg-bg">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-accent-blue/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 badge bg-accent/15 text-accent mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
        </svg>
        FREE TOOLS
      </div>

      <h1 class="font-display font-black tracking-tight text-4xl sm:text-5xl md:text-6xl text-white mb-4 leading-tight">
        Free tools for <span class="gradient-text">iOS developers.</span>
      </h1>
      <p class="text-lg text-text-muted leading-relaxed max-w-2xl mx-auto">
        Practical utilities that make shipping native Apple apps less painful. Each one solves a specific friction point we hit ourselves while building <a href="/apps/thinkbud" class="text-accent hover:underline">ThinkBud</a> and <a href="/apps/rolebud" class="text-accent hover:underline">RoleBud</a>.
      </p>
      <p class="text-sm text-text-muted/70 mt-3">
        Client-side. No signup. Nothing leaves your browser.
      </p>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="py-16 bg-surface border-y border-border/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-6">
        {tools.map((tool) => (
          <a
            href={`/tools/${tool.slug}`}
            class="group rounded-2xl border border-border bg-bg p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all flex flex-col"
          >
            <div class="flex items-start justify-between gap-3 mb-4">
              <div class="w-12 h-12 rounded-xl bg-accent/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={ICON_PATHS[tool.icon] || ICON_PATHS.shield} />
                </svg>
              </div>
              <span class="text-[10px] uppercase tracking-wider px-2 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 font-semibold">
                Live · Free
              </span>
            </div>

            <h2 class="font-display font-bold text-white text-xl mb-2 group-hover:text-accent transition-colors">
              {tool.title}
            </h2>
            <p class="text-sm text-text-muted leading-relaxed flex-1 mb-4">
              {tool.description}
            </p>
            <span class="text-xs font-mono text-text-muted/80 group-hover:text-accent transition-colors inline-flex items-center gap-1">
              Open tool
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </a>
        ))}

        <!-- Coming soon teaser -->
        <div class="rounded-2xl border border-dashed border-border bg-bg/50 p-6 flex flex-col items-center justify-center text-center">
          <div class="w-12 h-12 rounded-xl bg-surface border border-border flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-text-muted/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-white text-base mb-2">More tools, soon.</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            App Store screenshot template, Bundle ID checker, TestFlight link tester. Got an idea? <a href="/contact" class="text-accent hover:underline">Tell us.</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterSignup variant="hero" />
</PageLayout>
