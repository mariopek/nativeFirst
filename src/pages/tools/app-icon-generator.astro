---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterSignup from '../../components/blog/NewsletterSignup.astro';
import AppIconGenerator from '../../components/tools/AppIconGenerator';
import { SITE } from '../../lib/constants';

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'App Icon Generator for iOS, iPadOS, macOS, watchOS & visionOS',
  description:
    "Free Apple app icon generator with iOS 26 Liquid Glass support. Drop a single 1024×1024 source, get every required size across all Apple platforms plus tinted and dark variants — packaged as a Xcode-ready AppIcon.appiconset ZIP.",
  url: `${SITE.url}/tools/app-icon-generator`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  browserRequirements: 'Modern browser with JavaScript and Canvas API',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'NativeFirst', url: SITE.url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools` },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'App Icon Generator',
      item: `${SITE.url}/tools/app-icon-generator`,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What\'s the iOS 26 Liquid Glass icon system?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "iOS 26 redesigned how home-screen icons render. Each app icon now has up to three appearance variants: the default (full color), a tinted variant (a luminance-based monochrome that the system colors with the user's accent), and a dark variant (a darker version for dark mode). Apple's Asset Catalog supports all three via the appearances key in Contents.json. This generator produces all three from your single source.",
      },
    },
    {
      '@type': 'Question',
      name: 'How do I drop the generated AppIcon.appiconset into Xcode?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Unzip the downloaded AppIcon.appiconset.zip, then drag the AppIcon.appiconset folder into your Xcode project's Assets.xcassets in the Project Navigator. If Assets already has an AppIcon entry, delete it first or rename the new one. Xcode picks up the Contents.json automatically — no further config needed.",
      },
    },
    {
      '@type': 'Question',
      name: 'What should my source image look like?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A square 1024×1024 PNG with the icon centered, no rounded corners (Apple applies the squircle mask itself), and no transparent background unless your design intends it for dark mode visibility. SVG sources are accepted and rasterized at each target size for crisp results. Source images smaller than 1024×1024 will be flagged with a warning — they\'ll work but may look soft at the App Store size.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Xcode already do this?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Xcode 14+ generates basic iOS icon sizes from a single 1024×1024 source if you use a Single Size icon set. But it does not handle macOS, watchOS, visionOS, or iOS 26 Liquid Glass tinted/dark variants in one pass. This tool produces the full multi-platform set and the Liquid Glass variants together.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the auto-generated dark variant production-quality?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No — for production, you should design the dark variant by hand. Apple\'s guidance is that dark icons often need different contrast, slightly brighter outlines, and may even use a different color palette. The auto-darken in this tool (multiply by 0.55) is a reasonable starting point but not a substitute for hand-crafted design.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does the tool send my image anywhere?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Everything runs in your browser via the Canvas API. The image is never uploaded. The ZIP is generated client-side using JSZip and downloaded directly. Refresh the page and there\'s no trace.',
      },
    },
  ],
};
---

<PageLayout
  title="Free App Icon Generator for iOS 26 + macOS, watchOS, visionOS — Liquid Glass Variants Included | NativeFirst"
  description="Drop one 1024×1024 source. Get every Apple icon size — iPhone, iPad, Mac, Apple Watch, Vision Pro — plus iOS 26 Liquid Glass tinted and dark variants, packaged as Xcode-ready AppIcon.appiconset. Free, client-side, no signup, no watermarks."
  keywords="app icon generator, iOS app icon generator, iOS 26 liquid glass icon, app icon sizes, AppIcon.appiconset generator, Xcode app icon, macOS app icon, watchOS app icon, visionOS icon, tinted app icon iOS 26, dark mode app icon, app icon set generator, free icon generator no watermark"
>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative py-12 sm:py-16 overflow-hidden bg-bg">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-accent-blue/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-text-muted/80 mb-6">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/tools" class="hover:text-accent transition-colors">Tools</a>
        <span class="mx-2">/</span>
        <span class="text-text-muted">App Icon Generator</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 badge bg-accent/15 text-accent mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
          FREE TOOL · iOS 26 LIQUID GLASS READY
        </div>

        <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl md:text-5xl text-white mb-4 leading-tight">
          App Icon Generator for every Apple platform.
        </h1>
        <p class="text-lg text-text-muted leading-relaxed mb-2">
          Drop one <code class="font-mono text-base px-2 py-0.5 rounded bg-surface border border-border text-white">1024×1024</code> source. Get every required size for iPhone, iPad, Mac, Apple Watch, and Vision Pro — plus <strong class="text-white">iOS 26 Liquid Glass</strong> tinted and dark variants — packaged as an Xcode-ready <code class="font-mono text-base px-2 py-0.5 rounded bg-surface border border-border text-white">AppIcon.appiconset</code>.
        </p>
        <p class="text-sm text-text-muted/80">
          Client-side. No signup. No watermarks. Your image never leaves the browser.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick context -->
  <section class="bg-surface border-y border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <details class="group py-5">
        <summary class="cursor-pointer flex items-center justify-between gap-3 hover:opacity-80 transition-opacity">
          <h2 class="font-display font-semibold text-white text-base sm:text-lg">
            Why iOS 26 changed the icon game (read this if you're shipping a new app)
          </h2>
          <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-5 pt-5 border-t border-border/40 prose prose-invert prose-sm max-w-3xl prose-p:text-text-muted prose-strong:text-white prose-code:text-accent prose-code:font-mono prose-code:text-xs prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:bg-bg prose-code:border prose-code:border-border prose-code:before:content-[''] prose-code:after:content-[''] prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
          <p>
            Until iOS 26, every app shipped one icon. The system rendered it with rounded corners on the home screen and that was the entire deal. iOS 26 introduced <strong>Liquid Glass</strong> — a redesigned home-screen system where icons render in three appearance modes:
          </p>
          <ul>
            <li><strong>Default</strong> — your full-color icon as you've always shipped it</li>
            <li><strong>Tinted</strong> — a luminance-based monochrome that iOS colors with the user's accent. Your icon shows up as silver-on-black, then orange-on-black, then blue-on-black depending on user choice.</li>
            <li><strong>Dark</strong> — a separate dark-mode icon (you control the design entirely)</li>
          </ul>
          <p>
            Apple's <code>Asset Catalog</code> handles all three via the <code>appearances</code> key in <code>Contents.json</code>. The system picks which variant to render based on user preference and device theme. If you ship without these variants, your default icon shows everywhere — which works, but looks out of place when the user has tinted mode enabled.
          </p>
          <p>
            <strong>Most existing icon generators don't support this yet.</strong> They were built for the pre-iOS 26 world. This tool does — auto-generates the tinted variant from luminance, and a starter dark variant from auto-darken (replace it with a hand-crafted version for production).
          </p>
          <p class="text-text-muted/70 italic">
            Liquid Glass is also why we built the <a href="/blog/liquid-glass-apple-design-controversy-2026">Liquid Glass design coverage</a> on the blog — for indie devs caught off-guard by the shift.
          </p>
        </div>
      </details>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-12 sm:py-16 bg-bg">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <AppIconGenerator client:load />
    </div>
  </section>

  <!-- Detailed Xcode walkthrough — kept as deeper reference below the tool -->
  <section class="py-10 bg-surface border-y border-border/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <details class="group">
        <summary class="cursor-pointer flex items-center justify-between gap-3 hover:opacity-80 transition-opacity">
          <h2 class="font-display font-semibold text-white text-base sm:text-lg">
            Detailed Xcode walkthrough (the long version)
          </h2>
          <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <ol class="mt-4 pt-4 border-t border-border/40 space-y-3 text-sm text-text-muted leading-relaxed list-decimal list-inside">
          <li>Unzip the downloaded <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">AppIcon.appiconset.zip</code></li>
          <li>Open your Xcode project, find <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">Assets.xcassets</code> in the Project Navigator</li>
          <li>If there's already an <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">AppIcon</code> entry, delete it (right-click → Delete)</li>
          <li>Drag the unzipped <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">AppIcon.appiconset</code> folder into Assets.xcassets</li>
          <li>Build &amp; run — Xcode picks up <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">Contents.json</code> automatically. No manual config.</li>
          <li>Verify in Simulator: Settings → Display & Brightness → toggle dark mode and tint to confirm Liquid Glass variants render.</li>
        </ol>
      </details>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 sm:py-16 bg-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black tracking-tight text-2xl sm:text-3xl text-white mb-3">
        App Icon Generator FAQ
      </h2>
      <p class="text-text-muted mb-10">
        Everything an iOS dev hits when wiring up app icons in 2026.
      </p>

      <div class="space-y-4">
        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Doesn't Xcode already do this?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            Partially. Xcode 14+ auto-generates basic iOS sizes from a 1024×1024 source if you choose Single Size mode. But it doesn't handle macOS, watchOS, visionOS, or iOS 26 Liquid Glass tinted/dark variants in one pass. This tool produces all of them together, formatted as a drop-in <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">AppIcon.appiconset</code>.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              What should my source image look like?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            Square 1024×1024 PNG with the icon centered, no rounded corners (Apple applies the squircle mask itself), full bleed background. SVG sources are accepted and rasterized cleanly at each target size. Sources smaller than 1024×1024 work but get flagged as a warning — they may look soft at App Store sizes.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              How is the tinted variant generated?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            We compute Rec. 709 luminance per pixel, then output white pixels with alpha proportional to the source luminance. Bright areas of your icon stay solid; dark areas become transparent. The system then colors the white shape with the user's accent. This matches Apple's intended pipeline for tinted variants.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Is the auto-generated dark variant production-quality?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            No — for production, design the dark variant by hand. Apple's guidance is that dark icons often need different contrast, brighter outlines, and may use a different palette. The auto-darken in this tool (multiply by 0.55) is a starting point. After you ship a hand-crafted dark variant, replace the file inside <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">AppIcon.appiconset</code> and Xcode picks it up automatically.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Does the tool send my image anywhere?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            No. Image processing runs entirely in your browser via the Canvas API. The ZIP is generated client-side using JSZip and downloaded directly. We don't have a backend that sees your image. Refresh the page and there's no trace.
          </p>
        </details>

        <details class="group rounded-xl border border-border bg-surface p-5">
          <summary class="cursor-pointer flex items-center justify-between gap-3">
            <h3 class="font-display font-semibold text-white text-base pr-4">
              Why no visionOS layered icon support?
            </h3>
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
            visionOS uses 3D layered icons (front + middle + back) that require designer judgment about which elements pop forward. We provide the flat 1024×1024 fallback the system uses for non-3D contexts. For full layered visionOS icons, design the layers in your tool of choice and assemble the <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg border border-border text-white">.solidimagestack</code> by hand.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Cross-link cards -->
  <section class="py-12 bg-surface border-y border-border/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-5">
        <a
          href="/tools/aasa-validator"
          class="group rounded-2xl border border-border bg-bg p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2">
            Sister tool
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            Universal Links / AASA Validator
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Why your Universal Links open Safari instead of your app. Same iOS plumbing energy.
          </p>
        </a>

        <a
          href="/apps/thinkbud"
          class="group rounded-2xl border border-border bg-bg p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2 inline-flex items-center gap-2">
            <span>OUR APP</span>
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-500/10 border border-amber-500/30 text-amber-300 text-[9px]">★ 5★ Educational</span>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            ThinkBud — turn anything into mind maps + flashcards
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            We make ThinkBud — drop any link, PDF, or recording, get mind maps, FSRS-5 flashcards, AI podcasts. The energy behind these tools comes from shipping it.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter (bottom only) -->
  <NewsletterSignup variant="hero" />
</PageLayout>
