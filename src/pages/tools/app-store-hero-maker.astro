---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterSignup from '../../components/blog/NewsletterSignup.astro';
import AppStoreHeroMaker from '../../components/tools/AppStoreHeroMaker/index';
import { SITE } from '../../lib/constants';

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'App Store Hero Maker — Free Screenshot Generator with iOS 26 Liquid Glass',
  description:
    "Free App Store screenshot designer with 17 pre-designed presets, conversion guidance, iOS 26 Liquid Glass templates, brand color extraction, and bulk export to every Apple-required size. No signup, no watermarks, no ads.",
  url: `${SITE.url}/tools/app-store-hero-maker`,
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Web',
  browserRequirements: 'Modern browser with Canvas API + JavaScript',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'NativeFirst', url: SITE.url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: `${SITE.url}/tools` },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'App Store Hero Maker',
      item: `${SITE.url}/tools/app-store-hero-maker`,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why does this exist when there are paid tools like Mockuuups Studio and Previewed.app?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Most paid screenshot tools are pretty mockup makers — they output a phone with your screenshot inside and call it done. They don't run conversion checks on your headline, don't ship pre-designed presets you can drop in with one click, don't support iOS 26 Liquid Glass aesthetics, and they cost $30–150/month. We built a free tool that does all of that, because the next-best free option in 2026 still didn't.",
      },
    },
    {
      '@type': 'Question',
      name: 'What presets does the tool ship with?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '17 ready-to-edit presets across four categories: Hero (5 first-slide showpieces — Bold Streak, Soft Welcome, Liquid Glass, Brand Hero, Editorial Cover, AI Assistant), Feature (4 mid-deck explainers — Magazine Spread, Tech Punch, Before/After, Code Showcase), Social Proof (4 trust stats — 4.8 Stars, 127K Builders, Press Quote, 1M Downloads), and Trust (3 award/privacy badges — Editor’s Choice, Privacy First, Best of 2026, Award Footer). Each one is a complete composition — typography, color overrides, decorative emoji and badges, signature footers — so you swap in your screenshot, edit the copy, and ship.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the iOS 26 Liquid Glass template?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Liquid Glass is the iOS 26 visual language — frosted, translucent surfaces with backdrop-blur over a colorful background. The Liquid Glass template gives your App Store screenshots that aesthetic, signaling 'built for iOS 26' to App Store browsers. We're the first free generator to support it — most existing tools were built before iOS 26 shipped and still render flat captions.",
      },
    },
    {
      '@type': 'Question',
      name: 'What does the conversion guidance actually check?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Headline length and word count (bad copy = unreadable thumbnails — and 60% of conversions happen from the gallery thumbnail alone). WCAG color contrast (text vs background — Apple flags low-contrast screenshots in some regions). Conjunctions like "and" and "or" in headlines (each slide should sell ONE idea, not two). Missing screenshots. Real-time as you edit.',
      },
    },
    {
      '@type': 'Question',
      name: "How does brand color extraction work?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Upload your screenshot — we sample the most populated color buckets across the image, ignoring near-white, near-black, and very desaturated greys. The resulting palette becomes 3 background gradient suggestions that complement your app's existing brand. Runs entirely in your browser, takes under 50ms even on big screenshots.",
      },
    },
    {
      '@type': 'Question',
      name: 'Does the tool send my screenshots anywhere?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. All rendering happens in your browser using html-to-image (which uses native browser SVG serialization for pixel-perfect output). Brand color extraction runs in a Canvas. The ZIP is generated client-side via JSZip and downloaded directly. Your screenshots are never uploaded to a server.',
      },
    },
    {
      '@type': 'Question',
      name: 'What sizes does it export?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'iPhone: 6.9" (1320×2868, required for new submissions), 6.5" (1284×2778), 6.3" (1206×2622), 6.1" (1125×2436). iPad: 13" (2064×2752) and 12.9" Pro (2048×2732). Toggle which sizes to include. Files are named with sortable numeric prefixes so they upload to App Store Connect in the right order without manual reordering.',
      },
    },
    {
      '@type': 'Question',
      name: "Can I use my own custom colors instead of presets?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Right now the tool ships 5 conversion-tested theme presets (Clean Light, Dark Bold, Liquid Glass, Warm Editorial, NativeFirst Brand) plus brand color extraction that suggests gradients matching your screenshot. Full custom color editing for every text and background is coming in the next update. The presets cover ~80% of indie apps; let us know via newsletter reply if your case is the other 20%.',
      },
    },
  ],
};
---

<PageLayout
  title="Free App Store Screenshot Generator — 17 Presets + iOS 26 Liquid Glass | NativeFirst"
  description="Drop your iPhone screenshots, pick from 17 ready-made presets (Hero · Feature · Social Proof · Trust), get conversion-optimized App Store screenshots in every required size. Built-in conversion guidance, iOS 26 Liquid Glass, brand color extraction. Free, no signup, no watermarks."
  keywords="free app store screenshot generator, app store screenshot presets, iOS 26 Liquid Glass screenshots, app store conversion optimization, app store screenshot maker free, mockuuups alternative free, previewed.app alternative, iPhone screenshot mockup generator, App Store Connect screenshot sizes 2026, app store screenshot template, indie iOS dev tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="relative py-12 sm:py-16 overflow-hidden bg-bg">
    <div class="absolute top-1/4 right-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-accent-blue/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-text-muted/80 mb-6">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/tools" class="hover:text-accent transition-colors">Tools</a>
        <span class="mx-2">/</span>
        <span class="text-text-muted">App Store Hero Maker</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 badge bg-accent/15 text-accent mb-4">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z" />
          </svg>
          FREE TOOL · 17 PRESETS · iOS 26 LIQUID GLASS
        </div>

        <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl md:text-5xl text-white mb-4 leading-tight">
          App Store screenshots that actually convert.
        </h1>
        <p class="text-lg text-text-muted leading-relaxed mb-2">
          The free screenshot designer with what paid tools forgot — <strong class="text-white">17 ready-made presets</strong> (Hero · Feature · Social Proof · Trust), <strong class="text-white">iOS 26 Liquid Glass</strong>, live conversion guidance, brand color extraction, and bulk export to every Apple-required size.
        </p>
        <p class="text-sm text-text-muted/80">
          Client-side. No signup. No watermarks. Your screenshots never leave the browser.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-8 sm:py-12 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <AppStoreHeroMaker client:load />
    </div>
  </section>

  <!-- Why this beats paid tools -->
  <section class="py-12 sm:py-16 bg-surface border-y border-border/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-black tracking-tight text-2xl sm:text-3xl text-white mb-3">
          Why this exists.
        </h2>
        <p class="text-text-muted leading-relaxed max-w-2xl mx-auto">
          Existing paid tools (Mockuuups, Previewed, Screenshots.pro) all do roughly the same thing — frame your screenshot in a phone mockup and call it a day. None of them run conversion checks. None ship pre-designed presets you can drop in with one click. None support iOS 26 Liquid Glass. We needed a tool that did all three for our own apps. So we built it. Free.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="rounded-2xl border border-border bg-bg p-5">
          <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-display font-bold text-white text-sm mb-1.5">Conversion guidance</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Real-time checks: headline length for thumbnail readability, color contrast (WCAG), "and" conjunctions that kill clarity, missing assets. Stops you from shipping bad copy.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-5">
          <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>
          </div>
          <h3 class="font-display font-bold text-white text-sm mb-1.5">iOS 26 Liquid Glass</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Frosted glass caption template that mirrors how iOS 26 renders system surfaces. First free generator to ship this aesthetic — others still output flat captions from 2019.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-5">
          <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          </div>
          <h3 class="font-display font-bold text-white text-sm mb-1.5">17 ready-made presets</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Drop-in compositions across Hero, Feature, Social Proof, and Trust. Each one is fully styled — typography, color, decorative emoji, badges, footers — so you swap in your screenshot and ship.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-5">
          <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          </div>
          <h3 class="font-display font-bold text-white text-sm mb-1.5">Bulk export</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Every iPhone + iPad size in one ZIP. Numerically prefixed filenames sort cleanly in App Store Connect. No manual reordering.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 sm:py-16 bg-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-black tracking-tight text-2xl sm:text-3xl text-white mb-3">
        FAQ
      </h2>
      <p class="text-text-muted mb-10">
        Questions iOS devs hit when designing App Store screenshots in 2026.
      </p>

      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group rounded-xl border border-border bg-surface p-5">
            <summary class="cursor-pointer flex items-center justify-between gap-3">
              <h3 class="font-display font-semibold text-white text-base pr-4">{q.name}</h3>
              <svg class="w-5 h-5 text-text-muted flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 pt-3 border-t border-border text-sm text-text-muted leading-relaxed">
              {q.acceptedAnswer.text}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-link cards -->
  <section class="py-12 bg-surface border-y border-border/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-5">
        <a
          href="/tools/app-icon-generator"
          class="group rounded-2xl border border-border bg-bg p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2">
            Sister tool
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            App Icon Generator
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Drop one 1024×1024 source. Get every Apple icon size + iOS 26 Liquid Glass tinted and dark variants. Same energy as this tool, applied to icons.
          </p>
        </a>

        <a
          href="/apps/thinkbud"
          class="group rounded-2xl border border-border bg-bg p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-all"
        >
          <div class="text-[10px] uppercase tracking-wider font-semibold text-accent mb-2 inline-flex items-center gap-2">
            <span>OUR APP</span>
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded bg-amber-500/10 border border-amber-500/30 text-amber-300 text-[9px]">★ 5★ Educational</span>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-accent transition-colors">
            ThinkBud — turn anything into mind maps + flashcards
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">
            We make ThinkBud — drop any link, PDF, or recording, get mind maps, FSRS-5 flashcards, AI podcasts. The energy behind these tools comes from shipping it.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterSignup variant="hero" />
</PageLayout>
