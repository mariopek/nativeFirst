---
export const prerender = true;

import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../../lib/utils';
import { SITE, AUTHORS } from '../../../lib/constants';
import readingTime from 'reading-time';
import ThinkBudCallout from '../../../components/blog/ThinkBudCallout.astro';
import RelatedPosts from '../../../components/blog/RelatedPosts.astro';

export async function getStaticPaths() {
  const notes = await getCollection('fieldNotes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const rt = readingTime(note.body || '');
const shareUrl = encodeURIComponent(new URL(`/learn/field-notes/${note.id}`, Astro.site).toString());
const shareTitle = encodeURIComponent(note.data.title);
const authorInfo = AUTHORS[note.data.author] || { role: 'Team Member', bio: `Writer at NativeFirst, contributing to the field notes and helping build great Apple apps.` };

const levelColors: Record<string, string> = {
  intro: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  intermediate: 'bg-accent-blue/10 text-accent-blue border-accent-blue/20',
  advanced: 'bg-amber-500/10 text-amber-300 border-amber-500/20',
};

const levelLabels: Record<string, string> = {
  intro: 'Intro',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// BlogPosting JSON-LD
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: note.data.title,
  description: note.data.description,
  image: note.data.coverImage ? new URL(note.data.coverImage, Astro.site).toString() : undefined,
  url: new URL(`/learn/field-notes/${note.id}`, Astro.site).toString(),
  datePublished: note.data.pubDate.toISOString(),
  dateModified: (note.data.updatedDate || note.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: note.data.author },
  publisher: {
    '@type': 'Organization',
    name: 'NativeFirst',
    logo: { '@type': 'ImageObject', url: new URL('/apple-touch-icon.png', Astro.site).toString() },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(`/learn/field-notes/${note.id}`, Astro.site).toString() },
  keywords: note.data.topics.join(', '),
  proficiencyLevel: note.data.level,
  wordCount: rt.words,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: `${SITE.url}/learn` },
    { '@type': 'ListItem', position: 3, name: 'Field Notes', item: `${SITE.url}/learn/field-notes` },
    { '@type': 'ListItem', position: 4, name: note.data.title, item: new URL(`/learn/field-notes/${note.id}`, Astro.site).toString() },
  ],
};
---

<PageLayout
  title={`${note.data.title} — Field Notes | ${SITE.name}`}
  description={note.data.description}
  image={note.data.coverImage}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="py-12 sm:py-20 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="max-w-3xl mx-auto mb-8 text-sm text-text-muted/80">
        <a href="/learn" class="hover:text-accent transition-colors">Learn</a>
        <span class="mx-2">/</span>
        <a href="/learn/field-notes" class="hover:text-accent transition-colors">Field Notes</a>
      </nav>

      <!-- Article Header -->
      <header class="max-w-3xl mx-auto text-center mb-12">
        <!-- Level + Topics -->
        <div class="flex items-center justify-center gap-2 mb-6 flex-wrap">
          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full border text-xs font-medium ${levelColors[note.data.level] || levelColors.intermediate}`}>
            {levelLabels[note.data.level] || 'Intermediate'}
          </span>
          {note.data.topics.map((topic: string) => (
            <span class="tag">
              {topic}
            </span>
          ))}
        </div>

        <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl md:text-5xl text-white mb-6 leading-tight">
          {note.data.title}
        </h1>

        <div class="flex items-center justify-center gap-4 text-sm text-text-muted">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {note.data.author}
          </span>
          <span class="w-1 h-1 rounded-full bg-border"></span>
          <time datetime={note.data.pubDate.toISOString()}>
            {formatDate(note.data.pubDate)}
          </time>
          <span class="w-1 h-1 rounded-full bg-border"></span>
          <span>{rt.text}</span>
        </div>
      </header>

      <!-- Cover -->
      <div class="max-w-3xl mx-auto mb-12">
        {note.data.coverImage ? (
          <div class="rounded-2xl overflow-hidden shadow-lg bg-surface flex items-center justify-center">
            <img
              src={note.data.coverImage}
              alt={note.data.coverImageAlt || note.data.title}
              class="w-full max-h-[420px] object-contain"
              loading="eager"
            />
          </div>
        ) : (
          <div class="aspect-video rounded-2xl bg-gradient-to-br from-accent/10 to-accent-blue/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-accent/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
        )}
      </div>

      <!-- Content -->
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-invert prose-lg prose-headings:font-display prose-headings:font-bold prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-pre:bg-surface prose-pre:border prose-pre:border-border max-w-none">
          <Content />
        </div>

        <!-- Share -->
        <div class="border-t border-border pt-8 mt-12">
          <h3 class="font-display font-semibold text-lg text-white mb-4 text-center">
            Share this note
          </h3>
          <div class="flex items-center justify-center gap-3 flex-wrap">
            <a
              href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-2 text-text-muted hover:bg-border hover:text-white text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
              Share on X
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-2 text-text-muted hover:bg-border hover:text-white text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
            <button
              id="copy-link-btn"
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-2 text-text-muted hover:bg-border hover:text-white text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              <span id="copy-link-text">Copy Link</span>
            </button>
          </div>
        </div>

        <!-- Related Posts -->
        <RelatedPosts
          currentId={note.id}
          currentTags={note.data.topics}
          currentCollection="fieldNotes"
        />

        <!-- ThinkBud Callout -->
        <ThinkBudCallout context="field-note" />

        <!-- Author Card -->
        <div class="border-t border-border pt-10 mt-10">
          <div class="flex items-center gap-5 p-6 rounded-2xl bg-surface border border-border">
            <div class="w-16 h-16 rounded-full gradient-brand flex items-center justify-center flex-shrink-0">
              <span class="text-white font-display font-bold text-xl">
                {note.data.author.charAt(0)}
              </span>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-display font-semibold text-white">
                  {note.data.author}
                </p>
                <span class="tag">
                  {authorInfo.role}
                </span>
              </div>
              <p class="text-sm text-text-muted mt-1">
                {authorInfo.bio}
              </p>
            </div>
          </div>
        </div>

        <!-- Back to Field Notes -->
        <div class="text-center mt-12">
          <a
            href="/learn/field-notes"
            class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:gap-3 transition-all"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to all field notes
          </a>
        </div>
      </div>
    </div>
  </article>
</PageLayout>

<script>
  function initCopyLink() {
    const btn = document.getElementById('copy-link-btn');
    const text = document.getElementById('copy-link-text');
    if (!btn || !text) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        text.textContent = 'Copied!';
        setTimeout(() => {
          text.textContent = 'Copy Link';
        }, 2000);
      } catch {
        text.textContent = 'Failed';
        setTimeout(() => {
          text.textContent = 'Copy Link';
        }, 2000);
      }
    });
  }

  initCopyLink();
  document.addEventListener('astro:page-load', initCopyLink);
</script>
