---
export const prerender = true;

import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../../lib/utils';

const notes = (await getCollection('fieldNotes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const levelColors: Record<string, string> = {
  intro: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  intermediate: 'bg-accent-blue/10 text-accent-blue border-accent-blue/20',
  advanced: 'bg-amber-500/10 text-amber-300 border-amber-500/20',
};

const levelLabels: Record<string, string> = {
  intro: 'Intro',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};
---

<PageLayout
  title="Field Notes — iOS Development from Production | NativeFirst"
  description="Field Notes are the iOS development write-ups you only get from shipping the thing. Honest reports on Swift, SwiftUI, SwiftData, concurrency, and the rest of Apple's stack — no docs-tier explainers, no pretending the rough edges aren't there."
  keywords="iOS development field notes, Swift production lessons, SwiftUI real-world tips, SwiftData production issues, Swift concurrency migration, iOS engineering blog, native iOS development"
>
  <!-- Hero -->
  <section class="relative py-16 sm:py-24 overflow-hidden bg-bg">
    <div class="absolute inset-0 hero-gradient opacity-50"></div>
    <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-accent-blue/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 badge bg-accent/20 text-accent mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Field Notes
      </div>

      <h1 class="font-display font-black tracking-tight text-4xl sm:text-5xl md:text-6xl text-white mb-6 leading-tight">
        Notes from the <span class="gradient-text">field.</span>
        <br />
        <span class="text-text-muted text-3xl sm:text-4xl md:text-5xl">Mostly bruises.</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-muted mb-6 leading-relaxed max-w-2xl mx-auto">
        Field Notes are the iOS development write-ups you only get from <strong class="text-white">shipping the thing.</strong> No docs-tier explainers, no pretending the rough edges aren't there, no "here's how it should work" without the part where it didn't.
      </p>

      <p class="text-base text-text-muted/80 mb-10 leading-relaxed max-w-2xl mx-auto">
        Think of it as the conversation you'd have with another iOS dev at a conference, after the talks, when everyone's tired enough to be honest. Concurrency migrations that bit us. SwiftData edges we found in TestFlight at 2 AM. Xcode 26 features that look great in the keynote and weird in your project. The opinions you only earn by deploying.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 text-sm text-text-muted">
        <span class="inline-flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
          {notes.length} {notes.length === 1 ? 'note' : 'notes'} so far
        </span>
        <span class="hidden sm:block w-1 h-1 rounded-full bg-border"></span>
        <span>New ones drop when something interesting breaks</span>
      </div>
    </div>
  </section>

  <!-- What This Isn't (humor sub-hero) -->
  <section class="py-12 bg-surface border-y border-border/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-6 sm:gap-8">
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">✗</span>
            <h3 class="font-display font-semibold text-white">What this isn't</h3>
          </div>
          <ul class="space-y-2 text-sm text-text-muted leading-relaxed">
            <li>— A SwiftUI tutorial. Apple has 800.</li>
            <li>— A "10 Tips for iOS Developers" listicle.</li>
            <li>— Beginner-friendly. Mostly.</li>
            <li>— News. The blog handles news.</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-emerald-500/20 bg-bg p-6">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">✓</span>
            <h3 class="font-display font-semibold text-white">What this is</h3>
          </div>
          <ul class="space-y-2 text-sm text-text-muted leading-relaxed">
            <li>— Honest reports from shipped apps.</li>
            <li>— Specific bugs, specific fixes, specific tradeoffs.</li>
            <li>— Opinionated. Sometimes wrong. Usually useful.</li>
            <li>— What we wish someone had told us six months ago.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Notes Grid (matches blog card layout) -->
  <section class="py-16 sm:py-24 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {notes.length === 0 ? (
        <div class="text-center py-20 rounded-2xl border border-dashed border-border bg-surface max-w-2xl mx-auto">
          <h2 class="font-display font-bold text-2xl text-white mb-3">No notes yet.</h2>
          <p class="text-text-muted">First one drops soon. Probably right after something breaks.</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {notes.map((note) => (
            <a
              href={`/learn/field-notes/${note.id}`}
              class="group card overflow-hidden field-note-card"
            >
              <!-- Cover Image / Gradient Placeholder -->
              <div class="aspect-video bg-gradient-to-br from-accent/10 to-accent-blue/10 relative overflow-hidden">
                {note.data.coverImage ? (
                  <img
                    src={note.data.coverImage}
                    alt={note.data.coverImageAlt || note.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-12 h-12 text-accent/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>
                )}
              </div>

              <!-- Card Content -->
              <div class="p-6">
                <!-- Level + Topics -->
                <div class="flex items-center gap-2 mb-3 flex-wrap">
                  <span class={`inline-flex items-center px-2 py-0.5 rounded-full border text-[10px] font-semibold uppercase tracking-wider ${levelColors[note.data.level] || levelColors.intermediate}`}>
                    {levelLabels[note.data.level] || 'Intermediate'}
                  </span>
                  {note.data.topics.slice(0, 2).map((topic: string) => (
                    <span class="tag">
                      {topic}
                    </span>
                  ))}
                </div>

                <!-- Title -->
                <h2 class="font-display font-semibold text-lg text-white mb-2 group-hover:text-accent transition-colors line-clamp-2">
                  {note.data.title}
                </h2>

                <!-- Description -->
                <p class="text-sm text-text-muted line-clamp-2 mb-4">
                  {note.data.description}
                </p>

                <!-- Author & Meta -->
                <div class="flex items-center justify-between text-xs text-text-muted">
                  <div class="flex items-center gap-2">
                    <div class="w-5 h-5 rounded-full gradient-brand flex items-center justify-center flex-shrink-0">
                      <span class="text-white text-[8px] font-bold">{note.data.author.charAt(0)}</span>
                    </div>
                    <span class="font-medium text-text-muted">{note.data.author}</span>
                  </div>
                  <time datetime={note.data.pubDate.toISOString()}>
                    {formatDate(note.data.pubDate)}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Want more? -->
  <section class="py-16 bg-surface border-t border-border/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-4">
        Want the structured version?
      </h2>
      <p class="text-text-muted mb-8 leading-relaxed">
        Field Notes are scattered insights from shipping. If you want the same content organized into a path that takes you from zero to App Store, hit the <a href="/learn" class="text-accent hover:underline">Learn page</a>. Free SwiftUI courses, in order, no shortcuts.
      </p>
      <a
        href="/learn"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full gradient-brand text-white font-semibold text-sm hover:scale-105 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300"
      >
        Browse Courses
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </section>
</PageLayout>
