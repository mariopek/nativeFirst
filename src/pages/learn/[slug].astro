---
export const prerender = true;

import CourseLayout from '../../layouts/CourseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getCourseBySlug } from '../../lib/constants';

export async function getStaticPaths() {
  // Only published lessons. `ship-native` is a premium course that isn't public
  // yet — exclude it here (it previously redirected to /learn/ship-native at
  // runtime; a static build simply doesn't emit those lesson pages).
  const lessons = await getCollection(
    'course',
    ({ data }) => !data.draft && data.courseSlug !== 'ship-native'
  );

  return lessons.map((lesson) => {
    const courseSlug = lesson.data.courseSlug;
    const courseLessons = lessons
      .filter((l) => l.data.courseSlug === courseSlug)
      .sort(
        (a, b) =>
          (a.data.module * 100 + a.data.lesson) - (b.data.module * 100 + b.data.lesson)
      );

    const currentIndex = courseLessons.findIndex((l) => l.id === lesson.id);
    const prevLesson = currentIndex > 0 ? courseLessons[currentIndex - 1] : null;
    const nextLesson =
      currentIndex < courseLessons.length - 1 ? courseLessons[currentIndex + 1] : null;

    return {
      params: { slug: lesson.id },
      props: {
        lesson,
        courseLessons,
        prevLesson,
        nextLesson,
        currentIndex,
        courseData: getCourseBySlug(courseSlug),
      },
    };
  });
}

const { lesson, courseLessons, prevLesson, nextLesson, currentIndex, courseData } =
  Astro.props;

const { Content, headings } = await render(lesson);
---

<CourseLayout
  lesson={lesson}
  headings={headings}
  allLessons={courseLessons}
  prevLesson={prevLesson}
  nextLesson={nextLesson}
  currentIndex={currentIndex}
  courseData={courseData}
>
  <Content />
</CourseLayout>
