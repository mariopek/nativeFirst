---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import { APPS } from '../../lib/constants';

const app = APPS.thinkbud;

const featureIcons: Record<string, string> = {
  'import': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.338-2.32 3.75 3.75 0 013.83 5.346A4.5 4.5 0 0118 19.5H6.75z" /></svg>`,
  map: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
  layers: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  'check-circle': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  book: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  podcast: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" /></svg>`,
  chat: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
  'export': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>`,
};

const screenshots = [
  { src: '/images/apps/thinkbud-home.png', alt: 'ThinkBud home screen with learning materials', label: 'Home' },
  { src: '/images/apps/thinkbud-mindmap.png', alt: 'Interactive brain visual map in ThinkBud', label: 'Brain Map' },
  { src: '/images/apps/thinkbud-summary.png', alt: 'AI-generated summary of learning material', label: 'Summary' },
  { src: '/images/apps/thinkbud-flashcards.png', alt: 'Smart flash cards for spaced repetition learning', label: 'Flash Cards' },
  { src: '/images/apps/thinkbud-quiz.png', alt: 'Quiz mode with auto-generated questions', label: 'Quiz' },
  { src: '/images/apps/thinkbud-match.png', alt: 'Memory matching game for retention', label: 'Match Game' },
  { src: '/images/apps/thinkbud-export.png', alt: 'Export brain maps as PNG or presentations', label: 'Export' },
  { src: '/images/apps/thinkbud-explore.png', alt: 'Explore and discover topics with AI', label: 'Explore' },
];

const howItWorks = [
  { step: '1', title: 'Drop Your Content', description: 'Paste a link, upload a PDF, snap a photo, or record audio. ThinkBud accepts anything you throw at it.' },
  { step: '2', title: 'AI Does the Heavy Lifting', description: 'In seconds, ThinkBud generates a brain map, key summaries, flash cards, quizzes, and memory games from your content.' },
  { step: '3', title: 'Learn Your Way', description: 'Explore the visual mind map, drill with flash cards, test yourself with quizzes, or play matching games.' },
  { step: '4', title: 'Export & Share', description: 'Export your brain maps as beautiful PNG images, interactive HTML presentations, or PowerPoint slides.' },
];

const faqs = [
  {
    q: 'What can I import into ThinkBud?',
    a: 'Pretty much anything. Web links, PDF documents, images (including photos of textbook pages or handwritten notes), and audio files. ThinkBud processes them all and creates structured learning materials automatically.',
  },
  {
    q: 'What learning tools does ThinkBud generate?',
    a: 'From a single import, ThinkBud creates eight tools: interactive brain maps, AI summaries, flash cards with spaced repetition, quizzes, memory matching games, AI podcast overviews, AI chat for Q&A, and exportable presentations.',
  },
  {
    q: 'What export formats are available?',
    a: 'You can export brain maps as high-resolution PNG images, generate interactive HTML presentations you can share with anyone via a link, or create PowerPoint decks for more traditional presentations.',
  },
  {
    q: 'Is ThinkBud free?',
    a: 'ThinkBud offers a generous free tier to get you started. Premium features like advanced exports, unlimited imports, and extended AI capabilities are available through a subscription.',
  },
  {
    q: 'Does it work offline?',
    a: 'Your existing learning materials, flash cards, and brain maps are always accessible offline. Creating new materials from imported content requires an internet connection for AI processing.',
  },
  {
    q: 'Is ThinkBud coming to iPad and Mac?',
    a: 'Yes! Full iPad support with optimized layouts and Apple Pencil support is coming soon. A native Mac app is also in development. Your learning toolkit will be available on every Apple device.',
  },
  {
    q: 'Who is ThinkBud for?',
    a: 'Students, professionals, lifelong learners — anyone who needs to absorb information efficiently. Whether you are studying for exams, prepping for a presentation, or exploring a new hobby, ThinkBud adapts to your needs.',
  },
];
---

<PageLayout title={`${app.name} — AI Study App for iPhone | Mind Maps, Flash Cards, Quizzes & Podcasts`} description="Import any link, PDF, image, or audio and instantly get brain maps, AI summaries, flash cards with spaced repetition, quizzes, memory games, and AI podcasts. Export as PNG, HTML presentations, or PowerPoint. iPad and Mac coming soon.">

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center bg-bg hero-gradient overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: App Info -->
        <div class="text-center lg:text-left">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-8">
            <img
              src={app.icon}
              alt={`${app.name} app icon`}
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-[22px] shadow-2xl icon-glow"
            />
            <div>
              <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl text-white">
                {app.name}
              </h1>
              <div class="flex items-center gap-2 mt-1">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-bg/10 backdrop-blur-sm border border-white/10 text-xs text-text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2zm5 18a1 1 0 100-2 1 1 0 000 2z" />
                  </svg>
                  {app.platform}
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400">
                  <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                  Available Now
                </span>
              </div>
            </div>
          </div>

          <h2 class="font-display font-bold text-2xl sm:text-3xl md:text-4xl text-white mb-4 leading-tight">
            Drop Anything. <span class="gradient-text">Learn Everything.</span>
          </h2>

          <p class="text-lg text-text-muted mb-4 leading-relaxed max-w-lg mx-auto lg:mx-0">
            {app.description}
          </p>

          <p class="text-sm text-text-muted/70 mb-8 max-w-lg mx-auto lg:mx-0">
            Links, PDFs, images, audio — ThinkBud eats it all and turns it into a full learning toolkit with AI podcasts, chat, and spaced repetition. iPad and Mac support coming soon.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a
              href={app.appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-8 py-4 rounded-full gradient-brand text-white font-semibold text-base hover:scale-105 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Download on the App Store
            </a>
          </div>
        </div>

        <!-- Right: App Screenshot -->
        <div class="relative">
          <div class="relative mx-auto w-[280px] sm:w-[320px]">
            <div class="rounded-[3rem] border-[6px] border-border bg-surface-2 p-2 shadow-2xl">
              <!-- Notch -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-slate-700 rounded-b-2xl z-10"></div>
              <!-- Screen -->
              <div class="rounded-[2.4rem] overflow-hidden">
                <img
                  src="/images/apps/thinkbud-home.png"
                  alt="ThinkBud home screen"
                  class="w-full"
                  loading="eager"
                />
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-8 -z-10 bg-gradient-to-r from-accent/20 to-accent-blue/15 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          How <span class="gradient-text">ThinkBud</span> Works
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          From raw content to structured learning materials in four steps. No manual work required.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {howItWorks.map((item) => (
          <div class="relative text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-full gradient-brand flex items-center justify-center text-white font-bold text-xl">
              {item.step}
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {item.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 sm:py-28 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          One Import. <span class="gradient-text">Eight Learning Tools.</span>
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          ThinkBud doesn't just summarize your content — it transforms it into a complete learning system with AI podcasts, chat, and spaced repetition.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {app.features.map((feature) => (
          <div class="group relative rounded-2xl border border-border bg-bg p-8 hover:-translate-y-1 hover:shadow-xl hover:border-accent/40 transition-all duration-300">
            <div class="w-12 h-12 mb-5 rounded-xl gradient-brand flex items-center justify-center">
              <Fragment set:html={featureIcons[feature.icon] || featureIcons.map} />
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {feature.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Killer Feature: Export -->
  <section class="py-20 sm:py-28 bg-surface relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-sm font-medium text-accent mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
            Killer Feature
          </span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4 leading-tight">
            Export Brain Maps as <span class="gradient-text">Stunning Visuals</span>
          </h2>
          <p class="text-lg text-text-muted mb-6 leading-relaxed">
            This is where ThinkBud goes from useful to indispensable. Export your brain maps as high-resolution PNG images you can share, print, or embed anywhere.
          </p>
          <p class="text-lg text-text-muted mb-8 leading-relaxed">
            Need to present what you've learned? Generate interactive HTML presentations that run in any browser, or create polished PowerPoint decks — all from a single imported article, PDF, or audio file.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-text-muted">
              <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-white">PNG Export</strong> — High-res brain maps for sharing, printing, or embedding</span>
            </li>
            <li class="flex items-center gap-3 text-text-muted">
              <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-white">Interactive HTML</strong> — Presentations that run in any browser, no software needed</span>
            </li>
            <li class="flex items-center gap-3 text-text-muted">
              <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-white">PowerPoint</strong> — Professional slide decks generated from your learning content</span>
            </li>
          </ul>
          <a
            href={app.appStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full gradient-brand text-white font-semibold text-sm hover:scale-105 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300"
          >
            Try It Free
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <div class="relative">
          <div class="relative mx-auto w-[280px] sm:w-[320px]">
            <div class="rounded-[3rem] border-[6px] border-border bg-surface-2 p-2 shadow-2xl">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-slate-700 rounded-b-2xl z-10"></div>
              <div class="rounded-[2.4rem] overflow-hidden">
                <img
                  src="/images/apps/thinkbud-export.png"
                  alt="ThinkBud export screen showing PNG and presentation export options"
                  class="w-full"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="absolute -inset-8 -z-10 bg-gradient-to-r from-accent/15 to-emerald-500/15 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Coming Soon: iPad & Mac -->
  <section class="py-20 sm:py-28 bg-bg relative overflow-hidden">
    <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-accent-blue/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-sm font-medium text-amber-400 mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Coming Soon
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          ThinkBud is Going <span class="gradient-text">Everywhere</span>
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          Your learning toolkit is expanding to new platforms. Same powerful features, designed natively for every screen.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <!-- iPad -->
        <div class="rounded-2xl border border-border bg-surface p-8 text-center hover:-translate-y-1 hover:border-accent/40 transition-all duration-300">
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-accent/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5h3m-6.75 2.25h10.5a2.25 2.25 0 002.25-2.25v-15a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 4.5v15a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-2">iPad Full Support</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Full iPad optimization with multi-column layouts, keyboard shortcuts, and Apple Pencil support. Brain maps on a big screen — the way they were meant to be explored.
          </p>
          <span class="inline-block mt-4 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-medium text-amber-400">
            Coming Soon
          </span>
        </div>

        <!-- Mac -->
        <div class="rounded-2xl border border-border bg-surface p-8 text-center hover:-translate-y-1 hover:border-accent/40 transition-all duration-300">
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-accent/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-2">Mac App</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            A native macOS experience built from the ground up. Drag and drop files, use keyboard shortcuts, and study on the screen where you do your research.
          </p>
          <span class="inline-block mt-4 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-medium text-amber-400">
            Coming Soon
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshot Gallery -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          See <span class="gradient-text">ThinkBud</span> in Action
        </h2>
        <p class="text-lg text-text-muted max-w-xl mx-auto">
          A clean, focused interface designed to keep you learning — not fighting the app.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {screenshots.map((screenshot) => (
          <div class="group rounded-2xl overflow-hidden border border-border hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-surface">
            <div class="aspect-[9/16] overflow-hidden">
              <img
                src={screenshot.src}
                alt={screenshot.alt}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-3 text-center">
              <p class="text-xs font-medium text-text-muted">{screenshot.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          Frequently Asked Questions
        </h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-2xl border border-border bg-bg overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-6 text-white font-medium hover:text-accent transition-colors">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="py-20 sm:py-28 gradient-brand relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-40 h-40 border border-white/20 rounded-full"></div>
      <div class="absolute bottom-10 right-10 w-60 h-60 border border-white/20 rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 border border-white/10 rounded-full"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">Stop Studying Harder. Start Studying Smarter.</h2>
      <p class="text-lg text-white/80 mb-8 max-w-xl mx-auto">
        Download ThinkBud and turn any content into a full learning toolkit — brain maps, flash cards, quizzes, and exportable presentations.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={app.appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-bg text-accent font-semibold text-base hover:bg-surface hover:scale-105 hover:shadow-lg transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Download on the App Store
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-white/30 text-white font-semibold text-base hover:bg-white/10 hover:scale-105 transition-all duration-300"
        >
          Get in Touch
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>
  </section>

