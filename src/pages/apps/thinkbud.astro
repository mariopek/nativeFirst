  <!-- Privacy & Architecture -->
  <section class="py-20 sm:py-28 bg-bg relative overflow-hidden">
    <div class="absolute top-1/2 right-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-sm font-medium text-accent mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          Privacy by Design
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          No Accounts. No Tracking. <span class="gradient-text">Just Studying.</span>
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          ThinkBud is built on the Apple stack — your study materials live in your private iCloud, and you authenticate with Game Center. No emails, no passwords, no third-party servers in your data path.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">No Sign-Up</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Auth is handled by Apple Game Center. No email collection, no password resets, no leaked credentials.
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">iCloud Private Database</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Mind maps, flashcards, and progress live in your private CloudKit container. Apple-encrypted. Per-user. Never seen by us.
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">No IDFA, No ATT</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Analytics is GDPR-compliant TelemetryDeck. We count events, not people. No tracking prompt because there is nothing to track.
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">AI Keys Stay on Server</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            All AI calls go through a Cloudflare Worker proxy authenticated by HMAC. API keys never ship in the app binary.
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">Group Chat Auth</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Group messaging uses Apple-signed Game Center identity plus HMAC body signing. No phone numbers, no email lookup.
          </p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="font-display font-semibold text-lg text-white mb-2">Truly Cancel-Anytime</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Subscriptions are managed via the App Store. Cancel in Settings → Subscriptions. We never see your card details.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 sm:py-28 bg-surface">
