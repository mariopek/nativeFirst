---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import { APPS } from '../../lib/constants';

const app = APPS.thinkbud;

const featureIcons: Record<string, string> = {
  'import': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.338-2.32 3.75 3.75 0 013.83 5.346A4.5 4.5 0 0118 19.5H6.75z" /></svg>`,
  map: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
  layers: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  'check-circle': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  book: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  podcast: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" /></svg>`,
  chat: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
  'export': `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>`,
};

const screenshots = [
  { src: '/images/apps/thinkbud-home.png', alt: 'ThinkBud home screen with cards due for review, day streak, league rank, and study folders', label: 'Home' },
  { src: '/images/apps/thinkbud-mindmap.png', alt: 'Interactive mind map for Neuroplasticity Learning with central node and six branches', label: 'Mind Map' },
  { src: '/images/apps/thinkbud-summary.png', alt: 'AI-generated long-form summary of imported study material', label: 'Summary' },
  { src: '/images/apps/thinkbud-flashcards.png', alt: 'Auto-generated flashcards for The Cell Structure with FSRS-5 spaced repetition', label: 'Flashcards' },
  { src: '/images/apps/thinkbud-podcast.png', alt: 'AI Podcast configuration with length and style options for a 2-host conversation', label: 'AI Podcast' },
  { src: '/images/apps/thinkbud-chat.png', alt: 'Per-session AI chat that knows your imported material and suggests study prompts', label: 'Ask AI' },
  { src: '/images/apps/thinkbud-export.png', alt: 'Export sheet with PNG, Interactive HTML, PowerPoint, and shareable public link options', label: 'Export' },
  { src: '/images/apps/thinkbud-explore.png', alt: 'Discover Topics tab with bundled study examples and language-learning packs', label: 'Explore' },
  { src: '/images/apps/thinkbud-progress.png', alt: 'Progress dashboard with streak, badges, achievements, and weekly activity chart', label: 'Progress' },
  { src: '/images/apps/thinkbud-league.png', alt: 'Weekly League leaderboard showing Bronze tier ranking and XP per learner', label: 'Weekly League' },
  { src: '/images/apps/thinkbud-groups.png', alt: 'Study group chat with classmates, media sharing, and disappearing messages', label: 'Study Groups' },
  { src: '/images/apps/thinkbud-home-dark.png', alt: 'ThinkBud home screen in dark mode with widget hint and bronze league progress', label: 'Dark Mode' },
];

const howItWorks = [
  { step: '1', title: 'Drop Your Content', description: 'Paste a link, upload a PDF, snap a photo of your textbook, or record a lecture. ThinkBud accepts anything you throw at it — text, images, audio, or scanned docs.' },
  { step: '2', title: 'AI Builds Your Study Kit', description: 'In seconds, ThinkBud generates a mind map, key summaries, FSRS-5 flashcards, quizzes, cloze exercises, and a 2-host podcast — all from a single import.' },
  { step: '3', title: 'Learn Across Ten Modes', description: 'Explore the visual mind map, drill with flashcards, test yourself with quizzes, explain concepts in Feynman mode, listen to the podcast, or chat with the AI tutor.' },
  { step: '4', title: 'Compete, Share & Export', description: 'Climb the weekly league, share decks with study groups, or export your maps as PNG, interactive HTML, PowerPoint, or a public link anyone can view.' },
];

const faqs = [
  {
    q: 'What can I import into ThinkBud?',
    a: 'Pretty much anything. Web links, PDF documents, images (including photos of textbook pages or handwritten notes processed via Apple Vision OCR), and audio files transcribed with Whisper. ThinkBud processes them all and creates a complete study kit automatically.',
  },
  {
    q: 'What learning tools does ThinkBud generate from one import?',
    a: 'From a single import, ThinkBud generates ten study tools: an interactive mind map, an AI summary, FSRS-5 flashcards, multiple-choice quizzes, fill-in-the-blank cloze exercises, a Feynman-style explanation mode, a 2-host AI podcast, an audio review, an Ask AI per-session chat, and exportable presentations.',
  },
  {
    q: 'What is FSRS-5 and why does it matter?',
    a: 'FSRS-5 (Free Spaced Repetition Scheduler) is a modern, open-source memory algorithm that schedules each flashcard based on how well you actually know it — not a fixed interval like older SRS systems. It is the same algorithm used by serious memorization tools, and it means fewer reviews for cards you have mastered and more focus on the ones giving you trouble.',
  },
  {
    q: 'Can I study with friends?',
    a: 'Yes. Create or join Study Groups, share decks, and chat in real time — text, voice notes, photos, files, location, contacts, even disappearing messages. Group chat runs on a fully native Apple stack with push notifications and per-conversation TTLs. Auth uses Apple Game Center, so there are no separate accounts to manage.',
  },
  {
    q: 'How does the Weekly League work?',
    a: 'Earn XP for every review, quiz, podcast, and Feynman explanation, then compete in a five-tier weekly leaderboard — Bronze, Silver, Gold, Platinum, Diamond. Promotion and demotion happen each week. It is gamified the right way: quietly motivating, never pushy, and you can ignore it entirely if leaderboards are not your thing.',
  },
  {
    q: 'What export formats are available?',
    a: 'You can export brain maps as high-resolution PNG images, generate complete interactive HTML study files you can share via a link, create polished PowerPoint decks for traditional presentations, or publish a public link that anyone can view in a browser without installing the app.',
  },
  {
    q: 'Is ThinkBud free?',
    a: 'Yes. The free tier gives you one AI-generated study kit per day plus full access to the daily review, mind maps, exports, study groups, and weekly league. ThinkBud Pro removes the daily limit, unlocks unlimited Ask-AI chat, the 2-host AI Podcast, language-learning packs, and lifts every input limit (up to 100K characters, 100 PDF pages, 30 minutes of audio per import).',
  },
  {
    q: 'Does it work offline?',
    a: 'Your existing study kits, flashcards, mind maps, and chat history are always accessible offline — everything is stored locally with SwiftData. Creating new materials from imported content requires an internet connection because ThinkBud calls hosted AI models behind a privacy-preserving proxy.',
  },
  {
    q: 'Is ThinkBud available on iPad and Mac?',
    a: 'Yes. ThinkBud is a true universal Apple app — native on iPhone, iPad, and Mac, with iCloud sync via CloudKit keeping everything in lockstep across devices. The Mac app ships with a menu bar extra, a Command Palette (⌘K), Focus Review (⌘⇧F), and drag-and-drop file import.',
  },
  {
    q: 'How private is ThinkBud?',
    a: 'Very. There are no accounts to create — auth is handled via Apple Game Center identity. There is no IDFA, no cross-app tracking, and no ATT prompt. Analytics is GDPR-compliant TelemetryDeck which only counts events, not personal data. Your study materials are stored in your private iCloud database, which is end-to-end encrypted by Apple.',
  },
  {
    q: 'What does the Educational App Store certification mean?',
    a: 'The Educational App Store is an independent UK-based review platform that vets educational apps for pedagogical quality, age appropriateness, and overall user experience. ThinkBud earned a 5-star rating in 2026, which is their highest tier — awarded to apps they judge to be genuinely valuable for learning, not just well-designed.',
  },
  {
    q: 'Who is ThinkBud for?',
    a: 'Students at every level — high school, university, professional certifications. Lifelong learners. Language students. Professionals prepping for talks or onboarding into new domains. Anyone who needs to absorb information faster and remember it longer. ThinkBud adapts to whatever you are studying.',
  },
];
---

<PageLayout title={`${app.name} — AI Study App for iPhone, iPad & Mac | 5-Star Educational App Store Certified`} description="Import any link, PDF, image, or audio and instantly get mind maps, AI summaries, FSRS-5 flashcards, quizzes, cloze exercises, Feynman mode, and 2-host AI podcasts. Study with friends in groups, climb the weekly league, sync across iPhone, iPad, and Mac. 5-star Educational App Store certified.">

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center bg-bg hero-gradient overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: App Info -->
        <div class="text-center lg:text-left">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
            <img
              src={app.icon}
              alt={`${app.name} app icon`}
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-[22px] shadow-2xl icon-glow"
            />
            <div>
              <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl text-white">
                {app.name}
              </h1>
              <div class="flex items-center flex-wrap gap-2 mt-1">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-bg/10 backdrop-blur-sm border border-white/10 text-xs text-text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2zm5 18a1 1 0 100-2 1 1 0 000 2z" />
                  </svg>
                  {app.platform}
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400">
                  <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                  Available Now
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-medium text-amber-300">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                  v2.4 — 5★ Educational
                </span>
              </div>
            </div>
          </div>

          <h2 class="font-display font-bold text-2xl sm:text-3xl md:text-4xl text-white mb-4 leading-tight">
            Drop Anything. <span class="gradient-text">Learn Everything.</span>
          </h2>

          <p class="text-lg text-text-muted mb-4 leading-relaxed max-w-lg mx-auto lg:mx-0">
            Import any link, PDF, photo, or audio file. ThinkBud turns it into a complete study kit — mind maps, FSRS-5 flashcards, quizzes, AI podcasts, and Feynman explanations — all in seconds.
          </p>

          <p class="text-sm text-text-muted/70 mb-8 max-w-lg mx-auto lg:mx-0">
            Study with friends in real-time groups, climb the weekly league, and sync across iPhone, iPad, and Mac. Now Educational App Store certified.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a
              href={app.appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-8 py-4 rounded-full gradient-brand text-white font-semibold text-base hover:scale-105 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Download on the App Store
            </a>
          </div>
        </div>

        <!-- Right: App Screenshot -->
        <div class="relative">
          <div class="relative mx-auto w-[280px] sm:w-[320px]">
            <div class="rounded-[3rem] border-[6px] border-slate-300/40 bg-white/10 p-2 shadow-2xl backdrop-blur-sm">
              <!-- Dynamic Island -->
              <div class="absolute top-2 left-1/2 -translate-x-1/2 w-24 h-[22px] bg-black rounded-full z-10"></div>
              <!-- Screen -->
              <div class="rounded-[2.4rem] overflow-hidden">
                <img
                  src="/images/apps/thinkbud-home.png"
                  alt="ThinkBud home screen with daily review, spaced repetition card, day streak, and bronze league progress"
                  class="w-full"
                  loading="eager"
                />
              </div>
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-8 -z-10 bg-gradient-to-r from-accent/20 to-accent-blue/15 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Educational App Store Certification Banner -->
  <section class="py-16 sm:py-20 bg-gradient-to-b from-bg to-surface relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-[auto,1fr] gap-8 md:gap-12 items-center bg-surface/60 backdrop-blur-sm border border-amber-500/20 rounded-3xl p-8 md:p-12 shadow-2xl">
        <div class="flex justify-center md:justify-start">
          <img
            src="/images/apps/thinkbud-edu-cert.png"
            alt="Educational App Store Certified 2026 — 5-star rating badge for ThinkBud"
            class="w-44 sm:w-52 h-auto drop-shadow-2xl"
            loading="lazy"
          />
        </div>
        <div class="text-center md:text-left">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-xs font-semibold uppercase tracking-wider text-amber-300 mb-4">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
            </svg>
            5-Star Certified · 2026
          </span>
          <h2 class="font-display font-bold text-2xl sm:text-3xl md:text-4xl text-white mb-4 leading-tight">
            Vetted by the <span class="gradient-text">Educational App Store</span>
          </h2>
          <p class="text-base sm:text-lg text-text-muted leading-relaxed mb-3">
            ThinkBud earned a <strong class="text-white">5-star rating</strong> from the Educational App Store — an independent review platform that vets learning apps for pedagogical quality, age appropriateness, and overall experience.
          </p>
          <p class="text-sm text-text-muted/80 leading-relaxed">
            Their highest tier is reserved for apps they judge to be genuinely valuable for learning — not just polished. We are pretty proud of this one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          How <span class="gradient-text">ThinkBud</span> Works
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          From raw content to a structured study kit in four steps. No manual work required.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {howItWorks.map((item) => (
          <div class="relative text-center">
            <div class="w-14 h-14 mx-auto mb-5 rounded-full gradient-brand flex items-center justify-center text-white font-bold text-xl">
              {item.step}
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {item.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 sm:py-28 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          One Import. <span class="gradient-text">Twelve Tools to Learn With.</span>
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          ThinkBud doesn't just summarize your content — it builds a complete learning system around it, with FSRS-5 spaced repetition, Feynman explanations, social study groups, and a weekly league to keep you coming back.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {app.features.map((feature) => (
          <div class="group relative rounded-2xl border border-border bg-bg p-8 hover:-translate-y-1 hover:shadow-xl hover:border-accent/40 transition-all duration-300">
            <div class="w-12 h-12 mb-5 rounded-xl gradient-brand flex items-center justify-center">
              <Fragment set:html={featureIcons[feature.icon] || featureIcons.map} />
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {feature.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Killer Feature: Mind Map + Modes -->
  <section class="py-20 sm:py-28 bg-surface relative overflow-hidden">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-accent-blue/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="relative mx-auto w-[280px] sm:w-[320px]">
            <div class="rounded-[3rem] border-[6px] border-slate-300/40 bg-white/10 p-2 shadow-2xl backdrop-blur-sm">
              <div class="absolute top-2 left-1/2 -translate-x-1/2 w-24 h-[22px] bg-black rounded-full z-10"></div>
              <div class="rounded-[2.4rem] overflow-hidden">
                <img
                  src="/images/apps/thinkbud-mindmap.png"
                  alt="Interactive mind map of Neuroplasticity Learning with central node and six concept branches"
                  class="w-full"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="absolute -inset-8 -z-10 bg-gradient-to-r from-accent-blue/15 to-accent/15 rounded-full blur-3xl"></div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-sm font-medium text-accent-blue mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            Built for Real Studying
          </span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4 leading-tight">
            Ten Study Modes from <span class="gradient-text">a Single Import</span>
          </h2>
          <p class="text-lg text-text-muted mb-6 leading-relaxed">
            Other apps give you a summary and call it a day. ThinkBud generates ten different ways to engage with your material — because nobody learns the same way twice.
          </p>
          <ul class="space-y-3 mb-2">
            <li class="flex items-start gap-3 text-text-muted">
              <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
