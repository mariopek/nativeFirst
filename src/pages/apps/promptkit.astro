---
export const prerender = true;

import PageLayout from '../../layouts/PageLayout.astro';
import { APPS } from '../../lib/constants';

const app = APPS.promptkit;

const featureIcons: Record<string, string> = {
  library: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
  variable: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
  launch: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.841m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
  workflow: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75V4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V6.75" /></svg>`,
  community: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
  sync: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" /></svg>`,
  keyboard: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5M6 12h.008v.008H6V12zm3 0h.008v.008H9V12zm3 0h.008v.008H12V12zm3 0h.008v.008H15V12zm3 0h.008v.008H18V12z" /><rect x="2.25" y="5.25" width="19.5" height="13.5" rx="2" stroke="currentColor" stroke-width="2" fill="none" /></svg>`,
  quickaction: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M12 17.25h8.25" /><circle cx="6" cy="17.25" r="2.25" stroke="currentColor" stroke-width="2" fill="none" /></svg>`,
  faceid: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  accessibility: `<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75v3m-3-1.5h6" /></svg>`,
};

const faqs = [
  {
    q: 'What AI tools does PromptKit support?',
    a: 'At launch, PromptKit supports ChatGPT, Claude, Gemini, Perplexity, and Copilot. We use deep links to open the native app when installed, fall back to the web version, or copy to clipboard as a last resort. More AI targets will be added based on user requests.',
  },
  {
    q: 'Is PromptKit free?',
    a: 'PromptKit Pro is $2.99/month or $29.99 lifetime (launch promo pricing). Both plans include unlimited prompts, workflows, community features, and cloud sync. No free tier with limits — you get the full app from day one.',
  },
  {
    q: 'Does PromptKit work offline?',
    a: 'Yes. PromptKit is offline-first — your prompt library works without internet. Creating, editing, and launching prompts all work offline. Cloud sync and the community feed require a connection, but your personal library is always available.',
  },
  {
    q: 'What are prompt variables?',
    a: 'Variables let you add {{placeholders}} to your prompts. When you launch a prompt, PromptKit shows a quick form to fill in the blanks. For example: "Write a {{tone}} email about {{topic}} for {{audience}}" becomes a reusable template that works for any context.',
  },
  {
    q: 'Can I share prompts with my team?',
    a: 'The community feed lets you publish prompts publicly for anyone to discover and save. A dedicated Teams tier with shared private libraries and team workspaces is planned for v2.',
  },
  {
    q: 'Does PromptKit sync between iPhone and Mac?',
    a: 'Yes. PromptKit is a universal app that runs natively on both iOS and macOS. Your prompts, workflows, and settings sync in real-time across all your Apple devices.',
  },
];
---

<PageLayout title={`${app.name} — AI Prompt Manager for iOS & macOS`} description={app.description}>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": app.name,
    "description": app.description,
    "operatingSystem": "iOS, macOS",
    "applicationCategory": "ProductivityApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD",
      "description": "Free with in-app purchases"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  })} />

  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center bg-bg hero-gradient overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/15 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: App Info -->
        <div class="text-center lg:text-left">
          <div class="flex items-center justify-center lg:justify-start gap-4 mb-8">
            <img
              src={app.icon}
              alt={`${app.name} app icon`}
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-[22px] shadow-2xl icon-glow"
            />
            <div>
              <h1 class="font-display font-black tracking-tight text-3xl sm:text-4xl text-white">
                {app.name}
              </h1>
              <div class="flex items-center gap-2 mt-1">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-bg/10 backdrop-blur-sm border border-white/10 text-xs text-text-muted">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2zm5 18a1 1 0 100-2 1 1 0 000 2z" />
                  </svg>
                  iOS & macOS
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400">
                  <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                  Available Now
                </span>
              </div>
            </div>
          </div>

          <h2 class="font-display font-bold text-2xl sm:text-3xl md:text-4xl text-white mb-4 leading-tight">
            Your AI prompts. <span class="bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">Organized. Shared. Launched.</span>
          </h2>

          <p class="text-lg text-text-muted mb-8 leading-relaxed max-w-lg mx-auto lg:mx-0">
            {app.description}
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a
              href={app.appStoreUrl}
              class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-gradient-to-r from-violet-600 to-purple-600 text-white font-semibold text-base hover:scale-105 hover:shadow-lg hover:shadow-violet-500/25 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
              </svg>
              Download on the App Store
            </a>
            <a
              href="/blog/where-do-your-ai-prompts-go-to-die"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-border text-text-muted hover:text-white hover:border-violet-500/40 transition-all duration-300 text-sm font-medium"
            >
              Read the story
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Prompt cards mockup -->
        <div class="relative">
          <div class="relative mx-auto max-w-[400px]">
            <!-- Prompt card 1 -->
            <div class="rounded-2xl border border-border bg-surface p-5 shadow-xl mb-4 transform -rotate-1 hover:rotate-0 transition-transform duration-300">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-white font-semibold text-sm">Code Review Expert</h3>
                  <p class="text-text-muted text-xs mt-0.5">Review <span class="text-violet-400">{'{{language}}'}</span> code for bugs, security...</p>
                  <div class="flex gap-2 mt-2">
                    <span class="px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-medium">Development</span>
                    <span class="px-2 py-0.5 rounded-full bg-violet-500/10 text-violet-400 text-[10px] font-medium">Claude</span>
                  </div>
                </div>
                <span class="text-text-muted text-[11px]">847 uses</span>
              </div>
            </div>

            <!-- Prompt card 2 -->
            <div class="rounded-2xl border border-border bg-surface p-5 shadow-xl mb-4 transform rotate-1 hover:rotate-0 transition-transform duration-300">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-white font-semibold text-sm">Marketing Copy Writer</h3>
                  <p class="text-text-muted text-xs mt-0.5">Write <span class="text-amber-400">{'{{tone}}'}</span> copy for <span class="text-amber-400">{'{{product}}'}</span>...</p>
                  <div class="flex gap-2 mt-2">
                    <span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-[10px] font-medium">Marketing</span>
                    <span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-[10px] font-medium">ChatGPT</span>
                  </div>
                </div>
                <span class="text-text-muted text-[11px]">1.2k uses</span>
              </div>
            </div>

            <!-- Prompt card 3 — Workflow -->
            <div class="rounded-2xl border border-violet-500/30 bg-surface p-5 shadow-xl transform -rotate-0.5 hover:rotate-0 transition-transform duration-300">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /></svg>
                </div>
                <h3 class="text-white font-semibold text-sm">Blog Post Workflow</h3>
                <span class="ml-auto px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-medium">3 steps</span>
              </div>
              <div class="space-y-2">
                <div class="flex items-center gap-2 text-xs">
                  <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-[10px] font-bold">1</span>
                  <span class="text-text-muted">Research topic with Perplexity</span>
                </div>
                <div class="flex items-center gap-2 text-xs">
                  <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-[10px] font-bold">2</span>
                  <span class="text-text-muted">Draft article with Claude</span>
                </div>
                <div class="flex items-center gap-2 text-xs">
                  <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-[10px] font-bold">3</span>
                  <span class="text-text-muted">Polish copy with ChatGPT</span>
                </div>
              </div>
            </div>

            <!-- Decorative glow behind cards -->
            <div class="absolute -inset-8 -z-10 bg-gradient-to-r from-violet-500/15 to-purple-500/10 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Stats -->
  <section class="py-16 bg-surface border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-display font-bold text-3xl sm:text-4xl bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">73%</p>
          <p class="text-sm text-text-muted mt-1">lose prompts regularly</p>
        </div>
        <div>
          <p class="font-display font-bold text-3xl sm:text-4xl bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">68%</p>
          <p class="text-sm text-text-muted mt-1">rewrite the same ones</p>
        </div>
        <div>
          <p class="font-display font-bold text-3xl sm:text-4xl bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">4.2</p>
          <p class="text-sm text-text-muted mt-1">apps used to store prompts</p>
        </div>
        <div>
          <p class="font-display font-bold text-3xl sm:text-4xl bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">2.3h</p>
          <p class="text-sm text-text-muted mt-1">wasted per week on prompt management</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20 sm:py-28 bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          Everything Your Prompts <span class="bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">Deserve</span>
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          Stop treating your best prompts like disposable texts. PromptKit gives them a proper home.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {app.features.map((feature) => (
          <div class="group relative rounded-2xl border border-border bg-bg p-8 hover:-translate-y-1 hover:shadow-xl hover:border-violet-500/40 transition-all duration-300">
            <div class="w-12 h-12 mb-5 rounded-xl bg-gradient-to-br from-violet-600 to-purple-600 flex items-center justify-center">
              <Fragment set:html={featureIcons[feature.icon] || featureIcons.library} />
            </div>
            <h3 class="font-display font-semibold text-lg text-white mb-2">
              {feature.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshots Gallery -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          See It In Action
        </h2>
        <p class="text-lg text-text-muted max-w-xl mx-auto">
          A native app that feels right at home on your iPhone and Mac.
        </p>
      </div>

      <!-- iOS Screenshots -->
      <div class="mb-16">
        <h3 class="text-center font-display font-semibold text-xl text-white mb-8 flex items-center justify-center gap-2">
          <svg class="w-5 h-5 text-violet-400" fill="currentColor" viewBox="0 0 24 24"><path d="M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2zm5 18a1 1 0 100-2 1 1 0 000 2z" /></svg>
          iPhone
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {[
            { src: '/images/apps/Screenshots/AppStore/AppStore_01.png', alt: 'PromptKit Library — Save, organize and launch prompts to any AI' },
            { src: '/images/apps/Screenshots/AppStore/AppStore_02.png', alt: 'PromptKit Workflows — Chain prompts into multi-step AI pipelines' },
            { src: '/images/apps/Screenshots/AppStore/AppStore_03.png', alt: 'PromptKit Community — Discover and share prompts with trending templates' },
            { src: '/images/apps/Screenshots/AppStore/AppStore_04.png', alt: 'PromptKit Settings — Launch to any AI including ChatGPT, Claude, Gemini' },
            { src: '/images/apps/Screenshots/AppStore/AppStore_05.png', alt: 'PromptKit Usage Stats — Track your prompt analytics and favorite AI tools' },
            { src: '/images/apps/Screenshots/AppStore/AppStore_06.png', alt: 'PromptKit Keyboard Extension — Access prompts from any app' },
          ].map((shot) => (
            <div class="group rounded-2xl overflow-hidden border border-border hover:border-violet-500/40 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-surface">
              <img src={shot.src} alt={shot.alt} class="w-full h-auto" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- macOS Screenshots -->
      <div>
        <h3 class="text-center font-display font-semibold text-xl text-white mb-8 flex items-center justify-center gap-2">
          <svg class="w-5 h-5 text-violet-400" fill="currentColor" viewBox="0 0 24 24"><path d="M4 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm0 14h16v-2H4v2z" /></svg>
          Mac
        </h3>
