        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          Pick your categories during onboarding. Expert-crafted prompt packs load instantly — no internet required.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          { name: 'Development', count: 43, emoji: '💻' },
          { name: 'Marketing', count: 35, emoji: '📣' },
          { name: 'Copywriting', count: 28, emoji: '✍️' },
          { name: 'SEO', count: 19, emoji: '🔍' },
          { name: 'Social Media', count: 31, emoji: '📱' },
          { name: 'Data Analysis', count: 24, emoji: '📊' },
        ].map((pack) => (
          <div class="rounded-xl border border-border bg-surface p-4 text-center hover:border-violet-500/40 hover:-translate-y-0.5 transition-all duration-300">
            <span class="text-2xl mb-2 block">{pack.emoji}</span>
            <p class="text-sm font-medium text-white">{pack.name}</p>
            <p class="text-xs text-text-muted mt-0.5">{pack.count} prompts</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mb-4">
          Frequently Asked Questions
        </h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-border bg-bg overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer text-white font-medium hover:text-violet-400 transition-colors">
              {faq.q}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-sm text-text-muted leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Support CTA -->
  <section class="py-20 sm:py-28 bg-gradient-to-r from-violet-600 to-purple-600 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
