---
export const prerender = true;

import PageLayout from '../layouts/PageLayout.astro';
import NewsletterSignup from '../components/blog/NewsletterSignup.astro';
import { SITE } from '../lib/constants';

// Schema for the newsletter as a creative work
const newsletterSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'NativeFirst Field Notes',
  description: "Honest iOS dev write-ups from shipped apps. Weekly. Real bugs, real fixes, real tradeoffs — not tutorials.",
  url: `${SITE.url}/newsletter`,
  publisher: {
    '@type': 'Organization',
    name: 'NativeFirst',
    url: SITE.url,
  },
  inLanguage: 'en',
  audience: {
    '@type': 'Audience',
    audienceType: 'iOS Developers, SwiftUI Developers, Apple Platform Engineers',
  },
};
---

<PageLayout
  title="NativeFirst Field Notes — Weekly iOS Dev Newsletter"
  description="Subscribe to NativeFirst Field Notes. Honest iOS dev write-ups from shipped apps — Swift, SwiftUI, SwiftData, CloudKit, the whole Apple stack. Weekly. No tutorials, no fluff."
  keywords="iOS dev newsletter, SwiftUI newsletter, Swift newsletter, iOS development weekly, indie iOS dev newsletter, Apple platform newsletter, SwiftData newsletter, NativeFirst newsletter"
>
  <script type="application/ld+json" set:html={JSON.stringify(newsletterSchema)} />

  <!-- Hero with the form front and center -->
  <NewsletterSignup
    variant="hero"
    title="The iOS dev newsletter that respects your inbox."
    description="One email a week. Honest reports from shipping iOS apps in production — Swift concurrency migrations that bit us, SwiftData edges we found in TestFlight at 2 AM, the trade-offs you only earn by deploying. Free, no upsells, unsubscribe in one click."
    bullets={[
      'Every Tuesday, around 9 AM Belgrade time.',
      'Always 5–8 minutes to read. No giant walls of text.',
      'Written by Mario, who actually ships the apps he writes about.',
    ]}
  />

  <!-- What you'll get -->
  <section class="py-16 sm:py-20 bg-surface border-y border-border/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="section-label text-text-muted mb-3">What you get</p>
        <h2 class="font-display font-black tracking-tight text-2xl sm:text-3xl text-white mb-3">
          Notes you'd actually save to your "iOS dev" Notion folder.
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2">Field Notes</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            Honest reports from production — what worked, what quietly broke, what we'd do differently.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="w-10 h-10 rounded-lg bg-accent-blue/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2">Quick wins</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            One actionable Swift / SwiftUI tip per issue you can ship the same afternoon.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-bg p-6">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-white text-lg mb-2">First access</h3>
          <p class="text-sm text-text-muted leading-relaxed">
            New tools, courses, and ThinkBud features — newsletter readers get them before anyone else.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What you DON'T get -->
  <section class="py-12 bg-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-border bg-surface p-6 sm:p-8">
        <h3 class="font-display font-bold text-lg text-white mb-4 flex items-center gap-2">
          <span class="text-text-muted">What you </span><em class="text-accent not-italic">don't</em><span class="text-text-muted"> get</span>
        </h3>
        <ul class="space-y-2 text-sm text-text-muted leading-relaxed">
          <li class="flex items-start gap-2"><span class="text-text-muted/60 mt-1">—</span> Daily emails. Once a week, period.</li>
          <li class="flex items-start gap-2"><span class="text-text-muted/60 mt-1">—</span> "10 SwiftUI tips that will change your life." Listicle slop.</li>
          <li class="flex items-start gap-2"><span class="text-text-muted/60 mt-1">—</span> AI-generated content padded with em-dashes and "in today's fast-paced world."</li>
          <li class="flex items-start gap-2"><span class="text-text-muted/60 mt-1">—</span> Affiliate spam, sponsored posts disguised as content, paid plugs.</li>
          <li class="flex items-start gap-2"><span class="text-text-muted/60 mt-1">—</span> Your email shared, sold, or anywhere near a third party.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- About the writers -->
  <section class="py-12 bg-surface border-t border-border/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-5">
        <div class="w-16 h-16 rounded-full gradient-brand flex items-center justify-center flex-shrink-0">
          <span class="text-white font-display font-bold text-xl">N</span>
        </div>
        <div>
          <p class="text-sm text-text-muted leading-relaxed">
            <span class="font-semibold text-white">Written by the NativeFirst Dev Team.</span>
            iOS engineers with 15+ years of combined experience building for Apple platforms, currently shipping <a href="/apps/thinkbud" class="text-accent hover:underline">ThinkBud</a> (5★ Educational App Store certified), <a href="/apps/rolebud" class="text-accent hover:underline">RoleBud</a>, <a href="/apps/invoize" class="text-accent hover:underline">Invoize</a>, and <a href="/apps/promptkit" class="text-accent hover:underline">PromptKit</a>. Every field note comes from code we're actually running in production.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
