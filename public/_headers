# Cache control and crawler-friendly headers for Cloudflare Pages
#
# HTML caching strategy:
#   - Edge (Cloudflare CDN): cache for 1 day (s-maxage=86400)
#   - Browser: revalidate every request (max-age=0)
#   - stale-while-revalidate: serve stale up to 7 days while fetching fresh
#   - Cloudflare Pages auto-purges the edge cache on every successful deploy,
#     so a long s-maxage is safe — readers see new content seconds after push.

/*
  X-Robots-Tag: index, follow
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cache-Control: public, max-age=0, s-maxage=86400, stale-while-revalidate=604800

# Static assets — aggressive caching (1 year, immutable, hashed filenames)
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Sitemap and robots — crawlers need fresh copies
/sitemap-index.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml

/sitemap-*.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=3600

/rss.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml
